<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="VinhKhanhFood.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:VinhKhanhFood"
    Shell.FlyoutBehavior="Disabled">

    <Shell.Resources>
        <ResourceDictionary>
            <Style TargetType="TabBar">
                <Setter Property="Shell.TabBarBackgroundColor" Value="#222222" />

                <Setter Property="Shell.TabBarTitleColor" Value="#FF5722" />

                <Setter Property="Shell.TabBarUnselectedColor" Value="#AAAAAA" />
            </Style>
        </ResourceDictionary>
    </Shell.Resources>
    <TabBar>
        <Tab Title="Khám phá" Icon="home_icon.png">
            <ShellContent ContentTemplate="{DataTemplate local:MainPage}" />
        </Tab>

        <Tab Title="Yêu thích" Icon="heart_icon.png">
            <ShellContent ContentTemplate="{DataTemplate local:FavoritePage}" />
        </Tab>

        <Tab Title="Quét QR" Icon="qr_icon.png">
            <ShellContent ContentTemplate="{DataTemplate local:ScanQRPage}" />
        </Tab>

        <Tab Title="Cài đặt" Icon="settings_icon.png">
            <ShellContent ContentTemplate="{DataTemplate local:SettingsPage}" />
        </Tab>
    </TabBar>
</Shell>