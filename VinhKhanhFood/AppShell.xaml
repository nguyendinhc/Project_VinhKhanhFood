<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="VinhKhanhFood.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:VinhKhanhFood"
    Shell.FlyoutBehavior="Disabled">

    <Shell.Resources>
        <ResourceDictionary>
            <Style TargetType="TabBar">
                <Setter Property="Shell.BackgroundColor" Value="#FFF8F1" />
                <Setter Property="Shell.ForegroundColor" Value="#FF5722" />
                <Setter Property="Shell.TitleColor" Value="#2F2F2F" />

                <Setter Property="Shell.TabBarBackgroundColor" Value="#FFF8F1" />
                <Setter Property="Shell.TabBarForegroundColor" Value="#FF5722" />
                <Setter Property="Shell.TabBarTitleColor" Value="#FF5722" />
                <Setter Property="Shell.TabBarUnselectedColor" Value="#A08A7A" />
                <Setter Property="Shell.TabBarDisabledColor" Value="#CBBEB2" />
            </Style>
        </ResourceDictionary>
    </Shell.Resources>
    <TabBar>
        <Tab Title="Khám phá" Icon="home_icon.png">
            <ShellContent Route="main" ContentTemplate="{DataTemplate local:MainPage}" />
        </Tab>

        <Tab Title="Yêu thích" Icon="heart_icon.png">
            <ShellContent Route="favorites" ContentTemplate="{DataTemplate local:FavoritePage}" />
        </Tab>

        <Tab Title="Quét QR" Icon="qr_icon.png">
            <ShellContent Route="scanqr" ContentTemplate="{DataTemplate local:ScanQRPage}" />
        </Tab>

        <Tab Title="Cài đặt" Icon="settings_icon.png">
            <ShellContent Route="settings" ContentTemplate="{DataTemplate local:SettingsPage}" />
        </Tab>
    </TabBar>
</Shell>