<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhFood.SettingsPage"
             Title="Cài Đặt"
             BackgroundColor="#F5F7F8">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Frame CornerRadius="15" HasShadow="True" BorderColor="Transparent" BackgroundColor="White" Padding="15">
                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="12">
                    <VerticalStackLayout Grid.Column="0" Spacing="6">
                        <Label Text="Tài khoản đang đăng nhập" FontSize="14" FontAttributes="Bold" TextColor="Black" />
                        <Label x:Name="lblLoggedInUser" Text="Chưa đăng nhập" FontSize="16" FontAttributes="Bold" TextColor="#FF5722" />
                    </VerticalStackLayout>

                    <Button Grid.Column="1" Text="Đăng xuất" BackgroundColor="#DC2626" TextColor="White" FontAttributes="Bold" CornerRadius="18" HeightRequest="40" Clicked="OnLogoutClicked" />
                </Grid>
            </Frame>

            <Label Text="Tùy chỉnh ứng dụng" FontSize="22" FontAttributes="Bold" TextColor="#FF5722" />

            <Frame CornerRadius="15" HasShadow="True" BorderColor="Transparent" BackgroundColor="White" Padding="15">
                <VerticalStackLayout Spacing="10">
                    <Label Text="🌍 Ngôn ngữ thuyết minh" FontSize="16" FontAttributes="Bold" TextColor="Black" />
                    <Label Text="Chọn ngôn ngữ để máy đọc giới thiệu quán" FontSize="12" TextColor="Gray" />

                    <Picker x:Name="pckLanguage" Title="Chọn ngôn ngữ thuyết minh" SelectedIndexChanged="OnLanguageChanged" TextColor="Black">
                        <Picker.ItemsSource>
                            <x:Array Type="{x:Type x:String}">
                                <x:String>🇻🇳 Tiếng Việt</x:String>
                                <x:String>🇬🇧 English</x:String>
                                <x:String>🇰🇷 한국어 (Tiếng Hàn)</x:String>
                                <x:String>🇨🇳 中文 (Tiếng Trung)</x:String>
                                <x:String>🇯🇵 日本語 (Tiếng Nhật)</x:String>
                            </x:Array>
                        </Picker.ItemsSource>
                    </Picker>
                </VerticalStackLayout>
            </Frame>

            <Frame CornerRadius="15" HasShadow="True" BorderColor="Transparent" BackgroundColor="White" Padding="15">
                <Grid ColumnDefinitions="*, Auto">
                    <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                        <Label Text="📍 Tự động thuyết minh (GPS)" FontSize="16" FontAttributes="Bold" TextColor="Black" />
                        <Label Text="Tự phát loa khi đến gần quán (50m)" FontSize="12" TextColor="Gray" />
                    </VerticalStackLayout>

                    <Switch x:Name="swAutoPlay" Grid.Column="1" Toggled="OnAutoPlayToggled" ThumbColor="#FF5722" OnColor="#FFCCBC" />
                </Grid>
            </Frame>

            <Frame CornerRadius="15" HasShadow="True" BorderColor="Transparent" BackgroundColor="White" Padding="15">
                <VerticalStackLayout Spacing="10">
                    <Label Text="⬇️ Đồng bộ dữ liệu offline" FontSize="16" FontAttributes="Bold" TextColor="Black" />
                    <Label x:Name="lblOfflineSyncStatus" Text="Chưa đồng bộ" FontSize="12" TextColor="Gray" />
                    <Button x:Name="btnOfflineSync" Text="Đồng bộ ngay" BackgroundColor="#1E90FF" TextColor="White" FontAttributes="Bold" CornerRadius="12" HeightRequest="45" Clicked="OnOfflineSyncClicked" />
                </VerticalStackLayout>
            </Frame>

            <Button Text="Lưu Cài Đặt" BackgroundColor="#FF5722" TextColor="White" FontAttributes="Bold" CornerRadius="25" HeightRequest="50" Margin="0,20,0,0" Clicked="OnSaveSettingsClicked" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>