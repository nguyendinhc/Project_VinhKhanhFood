<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhFood.DetailPage"
             Title="Chi tiết địa điểm">

    <ScrollView>
        <VerticalStackLayout>

            <Image Source="{Binding ImageUrl}" 
                   HeightRequest="300" 
                   Aspect="AspectFill" />

            <VerticalStackLayout Padding="20" Spacing="15" Margin="0,-40,0,0">
                <Frame CornerRadius="25" HasShadow="True" BorderColor="Transparent" Padding="20" BackgroundColor="White">
                    <VerticalStackLayout Spacing="10">

                        <Label Text="{Binding Name}" FontSize="24" FontAttributes="Bold" TextColor="#333333" />
                        <Label Text="{Binding Status}" TextColor="Green" FontSize="14" FontAttributes="Italic" />

                        <BoxView HeightRequest="1" Color="LightGray" Margin="0,10" />

                        <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                            <Button Grid.Column="0" 
                                    Text="🔊 Thuyết minh" 
                                    Clicked="OnSpeakClicked" 
                                    BackgroundColor="#FF7F50" 
                                    TextColor="White" 
                                    FontAttributes="Bold"
                                    CornerRadius="12" />

                            <Button Grid.Column="1" 
                                    Text="📍 Chỉ đường" 
                                    Clicked="OnNavigateClicked" 
                                    BackgroundColor="#20B2AA" 
                                    TextColor="White" 
                                    FontAttributes="Bold"
                                    CornerRadius="12" />
                        </Grid>

                        <Button x:Name="btnFavorite"
                                Text="🤍 Thêm vào Yêu thích"
                                BackgroundColor="Transparent"
                                TextColor="#FF5722"
                                FontSize="16"
                                FontAttributes="Bold"
                                BorderColor="#FF5722"
                                BorderWidth="1"
                                CornerRadius="12"
                                HeightRequest="45"
                                Margin="0, 10, 0, 0"
                                Clicked="OnFavoriteClicked" />

                    </VerticalStackLayout>
                </Frame>

                <Label Text="Giới thiệu" FontSize="20" FontAttributes="Bold" Margin="0,10,0,0" TextColor="#1E90FF" />
                <Label Text="{Binding Introduction}" FontSize="16" LineHeight="1.5" TextColor="#555555" />

                <Label Text="Thông tin thêm" FontSize="20" FontAttributes="Bold" Margin="0,15,0,0" TextColor="#1E90FF" />
                <Label Text="{Binding Description}" FontSize="16" LineHeight="1.5" TextColor="#555555" />

                <Label Text="Thực đơn" FontSize="20" FontAttributes="Bold" Margin="0,15,0,0" TextColor="#1E90FF" />
                <CollectionView ItemsSource="{Binding Menus}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Padding="10" Margin="0,5" CornerRadius="12" HasShadow="True" BorderColor="#E0E0E0" BackgroundColor="White">
                                <Grid ColumnDefinitions="100,*" ColumnSpacing="12">
                                    <Image Source="{Binding ImageUrl}"
                                           HeightRequest="80"
                                           WidthRequest="100"
                                           Aspect="AspectFill" />
                                    <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                        <Label Text="{Binding FoodName}" FontAttributes="Bold" FontSize="16" TextColor="#333333" />
                                        <Label Text="{Binding Price, StringFormat='Giá: {0:N0}'}" FontSize="14" TextColor="#FF5722" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>