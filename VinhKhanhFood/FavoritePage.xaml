<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Name="FavoritePageRoot"
             x:Class="VinhKhanhFood.FavoritePage"
             Title="Quán Yêu Thích"
             BackgroundColor="#F5F7F8">

    <Grid Padding="15">
        <Label x:Name="lblEmpty" 
               Text="Chưa có quán nào được yêu thích 💔" 
               HorizontalOptions="Center" 
               VerticalOptions="Center" 
               FontSize="16" 
               TextColor="Gray"
               IsVisible="False" />

        <CollectionView x:Name="lstFavorites" 
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,0,0,10" Padding="10" CornerRadius="15" HasShadow="True" BorderColor="Transparent" BackgroundColor="White">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.FavoriteTapCommand}"
                                                  CommandParameter="{Binding .}" />
                        </Frame.GestureRecognizers>
                        <HorizontalStackLayout Spacing="15">

                            <Image Source="{Binding ImageUrl}" WidthRequest="80" HeightRequest="80" Aspect="AspectFill" />

                            <VerticalStackLayout VerticalOptions="Center" Spacing="5">
                                <Label Text="{Binding Name}" TextColor="#333333" FontSize="18" FontAttributes="Bold" />
                                <Label Text="{Binding Status}" TextColor="Green" FontSize="14" FontAttributes="Italic" />
                            </VerticalStackLayout>

                        </HorizontalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>