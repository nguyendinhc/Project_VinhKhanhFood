<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhFood.LoginPage"
             BackgroundColor="#F8FAFC"
             Title="Đăng nhập">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="220" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FFEDD5" Offset="0" />
                    <GradientStop Color="#FFEDD5" Offset="1" />
                </LinearGradientBrush>
            </Grid.Background>

            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="6">
                <Label Text="VĨNH KHÁNH FOOD" FontAttributes="Bold" FontSize="24" TextColor="#9A3412" HorizontalOptions="Center" />
                <Label Text="Trải nghiệm ẩm thực địa phương" FontSize="12" TextColor="#C2410C" HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>

        <Frame Grid.Row="1"
               CornerRadius="28"
               Padding="28"
               Margin="20,-40,20,20"
               BackgroundColor="White"
               HasShadow="True">
            <VerticalStackLayout Spacing="16">
                <Label Text="Đăng nhập tài khoản" FontAttributes="Bold" FontSize="18" TextColor="#0F172A" />

                <VerticalStackLayout Spacing="8">
                    <Label Text="Tên tài khoản" FontSize="12" TextColor="#64748B" />
                    <Entry x:Name="entryUsername" Placeholder="" BackgroundColor="#F8FAFC" TextColor="#0F172A" HeightRequest="44" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="8">
                    <Label Text="Mật khẩu" FontSize="12" TextColor="#64748B" />
                    <Entry x:Name="entryPassword" Placeholder="" IsPassword="True" BackgroundColor="#F8FAFC" TextColor="#0F172A" HeightRequest="44" />
                </VerticalStackLayout>

                <Label x:Name="lblError" IsVisible="False" TextColor="#DC2626" FontAttributes="Bold" FontSize="12" HorizontalOptions="Center" />

                <Button x:Name="btnLogin" Text="TIẾP TỤC" BackgroundColor="#EA580C" TextColor="White" CornerRadius="16" HeightRequest="50" Clicked="OnLoginClicked" />

                <ActivityIndicator x:Name="loadingIndicator" IsVisible="False" IsRunning="False" Color="#EA580C" HeightRequest="24" />
            </VerticalStackLayout>
        </Frame>
    </Grid>
</ContentPage>
