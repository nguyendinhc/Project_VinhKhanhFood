@page "/dashboard"
@inject HttpClient Http
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject IJSRuntime JS
@inject NavigationManager Navigation
@using System.Net.Http.Headers

<PageTitle>Quản lý Vĩnh Khánh</PageTitle>

<AuthorizeView>
    <Authorized>
        @if (showWelcomePopup)
        {
            <div class="login-success-backdrop" @onclick="CloseWelcomePopup"></div>
            <div class="login-success-popup alert alert-success shadow border-0">
                <button type="button" class="btn-close float-end" @onclick="CloseWelcomePopup"></button>
                <h4 class="mb-2 fw-bold"><i class="bi bi-check-circle-fill me-2"></i>Đăng nhập thành công!</h4>
                <span class="fs-5">Xin chào <b class="text-uppercase">@(string.IsNullOrWhiteSpace(displayName) ? context.User.Identity?.Name : displayName)</b></span>
            </div>
        }

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="m-0 text-primary fw-bold">Danh sách Địa Điểm</h2>
            <button class="btn btn-primary"><i class="bi bi-plus-circle"></i> Thêm quán mới</button>
        </div>

        @if (isLoading)
        {
            <div class="text-center mt-5">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-2 text-muted">Đang tải dữ liệu từ API...</p>
            </div>
        }
        else if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger mt-3">@errorMessage</div>
        }
        else
        {
            <div class="table-responsive shadow-sm rounded">
                <table class="table table-hover table-bordered bg-white m-0">
                    <thead class="table-dark text-center">
                        <tr>
                            <th width="10%">ID</th>
                            <th width="40%">Tên Quán</th>
                            <th width="30%">Tọa độ (Vĩ độ, Kinh độ)</th>
                            <th width="20%">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody class="align-middle">
                        @foreach (var quan in danhSachQuan)
                        {
                            <tr>
                                <td class="text-center">@quan.Poiid</td>
                                <td><strong class="text-primary">@quan.Name</strong></td>
                                <td class="text-center"><span class="badge bg-light text-dark border">@quan.Latitude, @quan.Longitude</span></td>
                                <td class="text-center">
                                    <button class="btn btn-outline-primary btn-sm me-1"><i class="bi bi-pencil-square"></i> Sửa</button>
                                    <button class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i> Xóa</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </Authorized>

    <NotAuthorized>
        <div class="alert alert-danger mt-5 shadow-sm border-0 text-center">
            <h3 class="alert-heading"><i class="bi bi-shield-x" style="font-size: 3rem;"></i></h3>
            <h4>CẢNH BÁO AN NINH</h4>
            <p>Phiên đăng nhập đã hết hạn</p>
            <a href="/" class="btn btn-danger mt-3 px-4 rounded-pill">Quay về Đăng nhập</a>
        </div>
    </NotAuthorized>
</AuthorizeView>

<style>
    .login-success-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.22);
        backdrop-filter: blur(2px);
        z-index: 1050;
        animation: fadeInBackdrop 0.25s ease-out;
    }

    .login-success-popup {
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        z-index: 1061;
        min-width: 520px;
        max-width: 640px;
        width: 52vw;
        padding: 1.25rem 1.5rem;
        border-radius: 16px;
        border: 1px solid rgba(16, 185, 129, 0.3) !important;
        background: linear-gradient(145deg, #ecfdf5 0%, #d1fae5 100%);
        animation: popupIn 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    }

    @@keyframes popupIn {
        from {
            opacity: 0;
            transform: translate(-50%, -46%) scale(0.96);
        }
        to {
            opacity: 1;
            transform: translate(-50%, -50%) scale(1);
        }
    }

    @@keyframes fadeInBackdrop {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    @@media (max-width: 768px) {
        .login-success-popup {
            min-width: 0;
            width: calc(100vw - 32px);
        }
    }
</style>

@code {
    private List<Poi> danhSachQuan = new();
    private string errorMessage = "";
    private string displayName = "";
    private bool isLoading = true;
    private bool showWelcomePopup = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // 1. Chỉ cần lấy Tên để hiển thị cho Popup
            displayName = await LocalStorage.GetItemAsStringAsync("displayName");
            if (string.IsNullOrWhiteSpace(displayName))
            {
                displayName = await JS.InvokeAsync<string>("sessionStorage.getItem", "displayName");
            }

            // 2. GỌI API SIÊU NGẮN GỌN (Mọi việc gắn Token Bearer đã có ông Giao liên lo!)
            danhSachQuan = await Http.GetFromJsonAsync<List<Poi>>("api/Pois") ?? new List<Poi>();
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            // Bị 401 (Hết hạn token) thì dọn dẹp và đuổi ra ngoài
            await LocalStorage.RemoveItemAsync("authToken");
            await LocalStorage.RemoveItemAsync("userRole");
            await JS.InvokeVoidAsync("sessionStorage.removeItem", "authToken");
            await JS.InvokeVoidAsync("sessionStorage.removeItem", "userRole");

            errorMessage = "Phiên đăng nhập đã hết hạn. Vui lòng đăng nhập lại.";
            Navigation.NavigateTo("/", forceLoad: true);
        }
        catch (Exception ex)
        {
            errorMessage = "Lỗi lấy dữ liệu từ Server!";
            Console.WriteLine("Lỗi API: " + ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && showWelcomePopup)
        {
            await Task.Delay(3000);
            showWelcomePopup = false;
            StateHasChanged(); // Ép giao diện vẽ lại để ẩn popup
        }
    }

    private void CloseWelcomePopup()
    {
        showWelcomePopup = false;
    }

    public class Poi
    {
        public int Poiid { get; set; }
        public string Name { get; set; }
        public double? Latitude { get; set; }
        public double? Longitude { get; set; }
    }
}
