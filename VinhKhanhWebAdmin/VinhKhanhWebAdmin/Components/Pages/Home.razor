@page "/home"
@attribute [Authorize(Roles = "Admin")]
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject IJSRuntime JS
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Tổng quan hê thống - VinhKhanhAdmin</PageTitle>

<div class="container-fluid p-0">
    @if (showWelcomePopup)
    {
        <div class="login-success-backdrop" @onclick="CloseWelcomePopup"></div>
        <div class="login-success-popup alert alert-success shadow border-0">
            <button type="button" class="btn-close float-end" @onclick="CloseWelcomePopup"></button>
            <h4 class="mb-2 fw-bold"><i class="bi bi-check-circle-fill me-2"></i>Đăng nhập thành công!</h4>
            <span class="fs-5">Xin chào <b class="text-uppercase">@displayName</b></span>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark m-0">@GetTimeGreeting(), <span class="text-primary">@displayName</span>! 👋</h2>
            <p class="text-muted m-0">Đây là tổng quan tình hình hệ thống hôm nay.</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-white border shadow-sm rounded-pill px-3">
                <i class="bi bi-calendar-event me-2 text-secondary"></i> @DateTime.Now.ToString("dd/MM/yyyy")
            </button>
            <button class="btn btn-outline-primary rounded-pill" @onclick="() => LoadHomeDataAsync()" disabled="@isLoading">
                <i class="bi bi-arrow-clockwise me-1"></i>Làm mới
            </button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center mt-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Đang tải dữ liệu trang chủ...</p>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger mt-3">@errorMessage</div>
    }
    else
    {
    <div class="row g-4 mb-4">
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm rounded-4 h-100 card-hover">
                <div class="card-body d-flex align-items-center p-4">
                    <div class="icon-box bg-primary-subtle text-primary rounded-circle me-4">
                        <i class="bi bi-shop-window fs-3"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-1 fw-semibold">Tổng Địa Điểm</h6>
                        <h2 class="fw-bold mb-0">@homeStats.TotalPois.ToString("N0")</h2>
                        <small class="text-muted">@homeStats.ActivePois hoạt động • @homeStats.PendingPois chờ duyệt</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm rounded-4 h-100 card-hover bg-warning-subtle">
                <div class="card-body d-flex align-items-center p-4">
                    <div class="icon-box bg-warning text-white rounded-circle me-4">
                        <i class="bi bi-person-lines-fill fs-3"></i>
                    </div>
                    <div>
                        <h6 class="text-dark-emphasis mb-1 fw-semibold">Chờ Phê Duyệt</h6>
                        <h2 class="fw-bold mb-0 text-dark-emphasis">@homeStats.PendingSubmissions.ToString("N0")</h2>
                        <small class="text-dark-emphasis">Từ yêu cầu đăng ký/cập nhật</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm rounded-4 h-100 card-hover">
                <div class="card-body d-flex align-items-center p-4">
                    <div class="icon-box bg-success-subtle text-success rounded-circle me-4">
                        <i class="bi bi-people-fill fs-3"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-1 fw-semibold">Tổng Users</h6>
                        <h2 class="fw-bold mb-0">@homeStats.TotalUsers.ToString("N0")</h2>
                        <small class="text-muted">Admin: @homeStats.AdminUsers • Owner: @homeStats.OwnerUsers</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm rounded-4 h-100 card-hover">
                <div class="card-body d-flex align-items-center p-4">
                    <div class="icon-box bg-info-subtle text-info rounded-circle me-4">
                        <i class="bi bi-cpu-fill fs-3"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-1 fw-semibold">Lượt ghé thăm hôm nay</h6>
                        <h2 class="fw-bold mb-0">@homeStats.TodayVisits.ToString("N0")</h2>
                        <small class="text-muted">Tổng lượt ghé thăm: @homeStats.TotalVisits.ToString("N0")</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8 mb-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white border-0 py-3 rounded-top-4 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold m-0"><i class="bi bi-clock-history me-2 text-primary"></i>Hoạt động gần đây</h5>
                    <a href="/logs" class="btn btn-sm btn-light rounded-pill px-3">Xem tất cả</a>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4">ID</th>
                                <th>Hành động</th>
                                <th>Người thực hiện</th>
                                <th>Thời gian</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (recentLogs.Count == 0)
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-4">Chưa có hoạt động gần đây.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var log in recentLogs)
                                {
                                    <tr>
                                        <td class="ps-4 fw-bold text-primary">#@log.LogId</td>
                                        <td>
                                            <span class="badge rounded-pill @GetActionBadgeClass(log.Action)">@(string.IsNullOrWhiteSpace(log.Action) ? "-" : log.Action)</span>
                                        </td>
                                        <td>@(string.IsNullOrWhiteSpace(log.FullName) ? (log.UserName ?? "Hệ thống") : $"{log.FullName} ({log.UserName})")</td>
                                        <td class="text-muted small">@(log.Timestamp?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-4 mb-4">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-primary text-white" style="background: linear-gradient(45deg, #0d6efd, #0a58ca);">
                <div class="card-body p-5 text-center d-flex flex-column justify-content-center align-items-center">
                    <i class="bi bi-rocket-takeoff-fill display-3 mb-4"></i>
                    <h4 class="fw-bold">Hệ thống đang hoạt động tốt!</h4>
                    <p class="opacity-75">Lần ghi nhận hoạt động gần nhất: @(homeStats.LatestActivityTime?.ToString("dd/MM/yyyy HH:mm") ?? "chưa có")</p>
                    <button class="btn btn-light text-primary rounded-pill px-4 mt-3 fw-bold shadow-sm">Kiểm tra trạng thái</button>
                </div>
            </div>
        </div>
    </div>
    }
</div>

<style>
    /* CSS riêng cho trang Home để làm đẹp các thẻ */
    .icon-box {
        width: 64px;
        height: 64px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0; /* Không bị bóp méo */
    }

    .card-hover {
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    }

        .card-hover:hover {
            transform: translateY(-5px); /* Bay lên nhẹ khi rê chuột */
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important;
        }

    .bg-primary-subtle {
        background-color: #cfe2ff !important;
    }

    .bg-success-subtle {
        background-color: #d1e7dd !important;
    }

    .bg-warning-subtle {
        background-color: #fff3cd !important;
    }

    .bg-info-subtle {
        background-color: #cff4fc !important;
    }

    .login-success-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.22);
        backdrop-filter: blur(2px);
        z-index: 1050;
        animation: fadeInBackdrop 0.25s ease-out;
    }

    .login-success-popup {
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        z-index: 1061;
        min-width: 520px;
        max-width: 640px;
        width: 52vw;
        padding: 1.25rem 1.5rem;
        border-radius: 16px;
        border: 1px solid rgba(16, 185, 129, 0.3) !important;
        background: linear-gradient(145deg, #ecfdf5 0%, #d1fae5 100%);
        animation: popupIn 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    }

    @@keyframes popupIn {
        from {
            opacity: 0;
            transform: translate(-50%, -46%) scale(0.96);
        }

        to {
            opacity: 1;
            transform: translate(-50%, -50%) scale(1);
        }
    }

    @@keyframes fadeInBackdrop {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@media (max-width: 768px) {
        .login-success-popup {
            min-width: 0;
            width: calc(100vw - 32px);
        }
    }
</style>

@code {
    private string displayName = "Admin";
    private bool showWelcomePopup;
    private bool isLoading = true;
    private string errorMessage = string.Empty;
    private HomeStats homeStats = new();
    private List<AuditLogItem> recentLogs = new();

    protected override async Task OnInitializedAsync()
    {
        await Task.CompletedTask;
    }

    private async Task LoadHomeDataAsync(int retryRemaining = 2)
    {
        try
        {
            isLoading = true;
            errorMessage = string.Empty;

            var analyticsTask = Http.GetFromJsonAsync<AnalyticsDashboard>("api/analytics/dashboard");
            var usersTask = Http.GetFromJsonAsync<UserPagedResult>("api/users?page=1&pageSize=1");
            var logsTask = Http.GetFromJsonAsync<AuditLogPagedResult>("api/audit-logs?page=1&pageSize=4");

            await Task.WhenAll(analyticsTask!, usersTask!, logsTask!);

            var analytics = analyticsTask.Result ?? new AnalyticsDashboard();
            var users = usersTask.Result ?? new UserPagedResult();
            var logs = logsTask.Result ?? new AuditLogPagedResult();

            recentLogs = logs.Items ?? new List<AuditLogItem>();
            homeStats = new HomeStats
            {
                TotalPois = analytics.TotalPois,
                ActivePois = analytics.ActivePois,
                PendingPois = analytics.PendingPois,
                PendingSubmissions = analytics.PendingSubmissions + analytics.PendingOwners + analytics.PendingPois,
                TotalVisits = analytics.TotalVisits,
                TodayVisits = analytics.VisitsTrend?.FirstOrDefault(x => x.Date.Date == DateTime.Today)?.TotalVisits ?? 0,
                TotalUsers = users.Summary.TotalUsers,
                AdminUsers = users.Summary.AdminCount,
                OwnerUsers = users.Summary.OwnerCount,
                LatestActivityTime = logs.Summary.LatestTimestamp
            };
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            if (retryRemaining > 0)
            {
                await Task.Delay(350);
                await LoadHomeDataAsync(retryRemaining - 1);
                return;
            }

            await LocalStorage.RemoveItemAsync("authToken");
            await JS.InvokeVoidAsync("sessionStorage.removeItem", "authToken");
            Navigation.NavigateTo("/", forceLoad: true);
        }
        catch (Exception ex)
        {
            errorMessage = $"Không thể tải dữ liệu trang chủ: {ex.Message}";
            homeStats = new HomeStats();
            recentLogs = new List<AuditLogItem>();
        }
        finally
        {
            isLoading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            var name = await LocalStorage.GetItemAsStringAsync("displayName");
            if (!string.IsNullOrWhiteSpace(name))
            {
                displayName = name;
            }
            else
            {
                var state = await JS.InvokeAsync<string>("sessionStorage.getItem", "displayName");
                if (!string.IsNullOrWhiteSpace(state))
                {
                    displayName = state;
                }
            }
        }
        catch
        {
        }

        await LoadHomeDataAsync();

        var shouldShowPopup = await JS.InvokeAsync<string>("sessionStorage.getItem", "showLoginSuccessPopup");
        if (!string.Equals(shouldShowPopup, "1", StringComparison.Ordinal))
        {
            StateHasChanged();
            return;
        }

        showWelcomePopup = true;
        await JS.InvokeVoidAsync("sessionStorage.removeItem", "showLoginSuccessPopup");
        StateHasChanged();

        await Task.Delay(3000);
        showWelcomePopup = false;
        StateHasChanged();
    }

    private void CloseWelcomePopup()
    {
        showWelcomePopup = false;
    }

    // Hàm tạo lời chào theo giờ
    private string GetTimeGreeting()
    {
        var hour = DateTime.Now.Hour;
        if (hour < 12) return "Chào buổi sáng";
        if (hour < 18) return "Chào buổi chiều";
        return "Chào buổi tối";
    }

    private static string GetActionBadgeClass(string? action)
    {
        if (string.IsNullOrWhiteSpace(action))
        {
            return "bg-secondary-subtle text-secondary border border-secondary-subtle";
        }

        var normalized = action.ToLowerInvariant();
        if (normalized.Contains("xóa") || normalized.Contains("delete"))
        {
            return "bg-danger-subtle text-danger border border-danger-subtle";
        }

        if (normalized.Contains("thêm") || normalized.Contains("create") || normalized.Contains("đăng ký"))
        {
            return "bg-success-subtle text-success border border-success-subtle";
        }

        if (normalized.Contains("cập nhật") || normalized.Contains("update"))
        {
            return "bg-info-subtle text-info border border-info-subtle";
        }

        return "bg-warning-subtle text-warning border border-warning-subtle";
    }

    public class HomeStats
    {
        public int TotalPois { get; set; }
        public int ActivePois { get; set; }
        public int PendingPois { get; set; }
        public int PendingSubmissions { get; set; }
        public int TotalUsers { get; set; }
        public int AdminUsers { get; set; }
        public int OwnerUsers { get; set; }
        public int TotalVisits { get; set; }
        public int TodayVisits { get; set; }
        public DateTime? LatestActivityTime { get; set; }
    }

    public class AnalyticsDashboard
    {
        public int TotalPois { get; set; }
        public int ActivePois { get; set; }
        public int PendingPois { get; set; }
        public int PendingSubmissions { get; set; }
        public int PendingOwners { get; set; }
        public int TotalVisits { get; set; }
        public List<VisitsTrendItem> VisitsTrend { get; set; } = new();
    }

    public class VisitsTrendItem
    {
        public DateTime Date { get; set; }
        public int TotalVisits { get; set; }
    }

    public class UserPagedResult
    {
        public UserSummary Summary { get; set; } = new();
    }

    public class UserSummary
    {
        public int TotalUsers { get; set; }
        public int AdminCount { get; set; }
        public int OwnerCount { get; set; }
    }

    public class AuditLogPagedResult
    {
        public List<AuditLogItem> Items { get; set; } = new();
        public AuditLogSummary Summary { get; set; } = new();
    }

    public class AuditLogSummary
    {
        public DateTime? LatestTimestamp { get; set; }
    }

    public class AuditLogItem
    {
        public int LogId { get; set; }
        public string? UserName { get; set; }
        public string? FullName { get; set; }
        public string? Action { get; set; }
        public DateTime? Timestamp { get; set; }
    }
}