@page "/menus"
@attribute [Authorize(Roles = "Admin,Owner")]
@inject HttpClient Http
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider
@using System.Net.Http.Headers
@using System.Text.Json

<PageTitle>Quản lý Menu</PageTitle>

<AuthorizeView>
    <Authorized>
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="m-0 text-primary fw-bold"><i class="bi bi-journal-text me-2"></i>Quản lý Menu</h2>
            <div class="d-flex gap-2">
                <button class="btn btn-outline-primary rounded-pill" @onclick="LoadMenus" disabled="@isLoading">
                    <i class="bi bi-arrow-clockwise me-1"></i>Làm mới
                </button>
                <button class="btn btn-primary rounded-pill" @onclick="OpenCreateForm">
                    <i class="bi bi-plus-circle me-1"></i>Thêm món
                </button>
            </div>
        </div>

        @if (showForm)
        {
            <div class="modal fade show d-block" style="background: rgba(0,0,0,0.6); backdrop-filter: blur(5px);">
                <div class="modal-dialog modal-dialog-centered modal-lg">
                    <div class="modal-content border-0 shadow-lg rounded-4">
                        <div class="modal-header bg-primary text-white rounded-top-4 border-0">
                            <h5 class="modal-title fw-bold"><i class="bi bi-journal-text me-2"></i>@(isEditMode ? "Cập nhật món" : "Thêm món mới")</h5>
                            <button type="button" class="btn-close btn-close-white" @onclick="CloseForm"></button>
                        </div>
                        <div class="modal-body p-4 bg-light">
                            @if (!string.IsNullOrWhiteSpace(formError))
                            {
                                <div class="alert alert-danger">@formError</div>
                            }
                            <div class="row g-3">
                                <div class="col-lg-4">
                                    <label class="form-label fw-bold text-dark">Quán</label>
                                    <select class="form-select shadow-sm border-0" @bind="menuForm.Poiid" disabled="@(!ownerPois.Any())">
                                        <option value="">-- Chọn quán --</option>
                                        @foreach (var poi in ownerPois)
                                        {
                                            <option value="@poi.Poiid">@poi.Name</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-lg-4">
                                    <label class="form-label fw-bold text-dark">Tên món</label>
                                    <input class="form-control shadow-sm border-0" @bind="menuForm.FoodName" placeholder="Ví dụ: Ốc len xào dừa" />
                                </div>
                                <div class="col-lg-2">
                                    <label class="form-label fw-bold text-dark">Giá</label>
                                    <input class="form-control shadow-sm border-0" type="number" @bind="menuForm.Price" placeholder="20000" />
                                </div>
                                <div class="col-lg-2">
                                    <label class="form-label fw-bold text-dark">Ảnh (URL)</label>
                                    <input class="form-control shadow-sm border-0" @bind="menuForm.Image" placeholder="https://..." />
                                    <InputFile OnChange="OnMenuImageSelectedAsync" class="form-control mt-2" accept="image/*" />
                                    @if (isUploadingImage)
                                    {
                                        <div class="small text-muted mt-1">Đang tải ảnh...</div>
                                    }
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer bg-white border-0 rounded-bottom-4 shadow-sm">
                            <button type="button" class="btn btn-outline-secondary px-4 rounded-pill" @onclick="CloseForm" disabled="@isSaving">Hủy</button>
                            <button type="button" class="btn btn-primary px-4 rounded-pill shadow-sm fw-bold" @onclick="SaveMenuAsync" disabled="@isSaving">
                                @(isSaving ? "Đang lưu..." : "Lưu")
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (isLoading)
        {
            <div class="text-center mt-5">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-2 text-muted">Đang tải danh sách món ăn...</p>
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="alert alert-danger mt-3">@errorMessage</div>
        }
        else
        {
            <div class="table-responsive shadow-sm rounded border-0">
                <table class="table table-hover align-middle bg-white m-0 w-100">
                    <thead class="table-dark text-center">
                        <tr>
                            <th width="8%">ID</th>
                            <th width="12%">Ảnh</th>
                            <th width="35%" class="text-start">Tên món</th>
                            <th width="15%">Giá</th>
                            <th width="24%" class="text-start">Quán</th>
                            <th width="16%">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody class="text-center">
                        @if (menus.Count == 0)
                        {
                            <tr>
                                <td colspan="6" class="text-muted py-4">Chưa có món ăn nào trong bảng Menu.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var menu in menus)
                            {
                                <tr>
                                    <td><span class="text-muted small">#@menu.MenuId</span></td>
                                    <td>
                                        <img src="@(string.IsNullOrWhiteSpace(menu.Image) ? "img/no-image.png" : menu.Image)"
                                             class="rounded shadow-sm" style="width: 50px; height: 50px; object-fit: cover;" />
                                    </td>
                                    <td class="text-start">
                                        <div class="fw-bold text-primary">@menu.FoodName</div>
                                    </td>
                                    <td>
                                        <span class="badge bg-success-subtle text-success border border-success-subtle">
                                            @(menu.Price.HasValue ? string.Format("{0:N0}đ", menu.Price.Value) : "Chưa cập nhật")
                                        </span>
                                    </td>
                                    <td class="text-start">
                                        @(!string.IsNullOrWhiteSpace(menu.PoiName) ? menu.PoiName : "Không xác định")
                                    </td>
                                    <td>
                                        <div class="d-flex justify-content-center gap-2">
                                            <button class="btn btn-sm btn-outline-primary" @onclick="() => StartEdit(menu)">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteMenuAsync(menu)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <div class="alert alert-danger mt-4">Bạn chưa đăng nhập. Vui lòng quay lại trang đăng nhập.</div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private readonly List<MenuItem> menus = new();
    private readonly List<OwnerPoi> ownerPois = new();
    private MenuFormModel menuForm = new();
    private bool isLoading = true;
    private bool isSaving;
    private bool showForm;
    private bool isEditMode;
    private string errorMessage = string.Empty;
    private string formError = string.Empty;
    private bool isAdmin;
    private bool isUploadingImage;

    protected override async Task OnInitializedAsync()
    {
        await LoadUserRoleAsync();
        await LoadOwnerPois();
        await LoadMenus();
    }

    private async Task OnMenuImageSelectedAsync(InputFileChangeEventArgs e)
    {
        formError = string.Empty;

        var file = e.File;
        if (file == null)
        {
            return;
        }

        isUploadingImage = true;
        try
        {
            using var content = new MultipartFormDataContent();
            await using var stream = file.OpenReadStream(5 * 1024 * 1024);
            var fileContent = new StreamContent(stream);
            fileContent.Headers.ContentType = new MediaTypeHeaderValue(file.ContentType);
            content.Add(fileContent, "file", file.Name);

            var response = await Http.PostAsync("api/uploads/menu", content);
            if (!response.IsSuccessStatusCode)
            {
                var message = await response.Content.ReadAsStringAsync();
                formError = string.IsNullOrWhiteSpace(message) ? "Không thể tải ảnh." : message;
                return;
            }

            var json = await response.Content.ReadAsStringAsync();
            using var document = JsonDocument.Parse(json);
            if (document.RootElement.TryGetProperty("url", out var urlElement))
            {
                menuForm.Image = urlElement.GetString();
            }
        }
        catch (Exception ex)
        {
            formError = $"Không thể tải ảnh: {ex.Message}";
        }
        finally
        {
            isUploadingImage = false;
        }
    }

    private async Task LoadUserRoleAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        isAdmin = authState.User?.IsInRole("Admin") == true;
    }

    private async Task LoadMenus()
    {
        try
        {
            isLoading = true;
            errorMessage = string.Empty;

            var data = await Http.GetFromJsonAsync<List<MenuItem>>("api/menu");
            menus.Clear();
            if (data is not null)
            {
                menus.AddRange(data);
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Không thể tải danh sách menu: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadOwnerPois()
    {
        try
        {
            var endpoint = isAdmin ? "api/pois" : "api/pois/owner";
            var data = await Http.GetFromJsonAsync<List<OwnerPoi>>(endpoint);
            ownerPois.Clear();
            if (data is not null)
            {
                ownerPois.AddRange(data);
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Không thể tải danh sách quán: {ex.Message}";
        }
    }

    private void OpenCreateForm()
    {
        formError = string.Empty;
        isEditMode = false;
        showForm = true;
        menuForm = new MenuFormModel
        {
            Poiid = ownerPois.FirstOrDefault()?.Poiid
        };
    }

    private void StartEdit(MenuItem menu)
    {
        formError = string.Empty;
        isEditMode = true;
        showForm = true;
        menuForm = new MenuFormModel
        {
            MenuId = menu.MenuId,
            Poiid = menu.Poiid,
            FoodName = menu.FoodName,
            Price = menu.Price,
            Image = menu.Image
        };
    }

    private void CloseForm()
    {
        showForm = false;
        isEditMode = false;
        formError = string.Empty;
    }

    private async Task SaveMenuAsync()
    {
        formError = string.Empty;

        if (!ownerPois.Any())
        {
            formError = "Tài khoản chưa được gán quán để quản lý menu.";
            return;
        }

        if (menuForm.Poiid == null)
        {
            formError = "Vui lòng chọn quán.";
            return;
        }

        if (string.IsNullOrWhiteSpace(menuForm.FoodName))
        {
            formError = "Vui lòng nhập tên món.";
            return;
        }

        isSaving = true;
        try
        {
            HttpResponseMessage response;
            if (isEditMode)
            {
                response = await Http.PutAsJsonAsync($"api/menu/{menuForm.MenuId}", menuForm);
            }
            else
            {
                response = await Http.PostAsJsonAsync("api/menu", menuForm);
            }

            if (!response.IsSuccessStatusCode)
            {
                var message = await response.Content.ReadAsStringAsync();
                formError = string.IsNullOrWhiteSpace(message) ? "Không thể lưu món ăn." : message;
                return;
            }

            await LoadMenus();
            CloseForm();
        }
        catch (Exception ex)
        {
            formError = $"Không thể lưu món ăn: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DeleteMenuAsync(MenuItem menu)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Xóa món '{menu.FoodName}'?");
        if (!confirmed)
        {
            return;
        }

        try
        {
            var response = await Http.DeleteAsync($"api/menu/{menu.MenuId}");
            if (!response.IsSuccessStatusCode)
            {
                var message = await response.Content.ReadAsStringAsync();
                errorMessage = string.IsNullOrWhiteSpace(message) ? "Không thể xóa món ăn." : message;
                return;
            }

            await LoadMenus();
        }
        catch (Exception ex)
        {
            errorMessage = $"Không thể xóa món ăn: {ex.Message}";
        }
    }

    public class MenuItem
    {
        public int MenuId { get; set; }
        public int? Poiid { get; set; }
        public string FoodName { get; set; } = string.Empty;
        public decimal? Price { get; set; }
        public string? Image { get; set; }
        public string? PoiName { get; set; }
    }

    public class OwnerPoi
    {
        public int Poiid { get; set; }
        public string Name { get; set; } = string.Empty;
    }

    public class MenuFormModel
    {
        public int MenuId { get; set; }
        public int? Poiid { get; set; }
        public string FoodName { get; set; } = string.Empty;
        public decimal? Price { get; set; }
        public string? Image { get; set; }
    }
}
