@page "/pois"
@attribute [Authorize(Roles = "Admin")]
@inject HttpClient Http
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject IJSRuntime JS
@inject NavigationManager Navigation
@using System.Net.Http.Headers
@using Microsoft.JSInterop
@using System.Net.Http.Headers
@using System.Text.Json

<PageTitle>Quản lý Vĩnh Khánh</PageTitle>

<AuthorizeView>
    <Authorized>
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="m-0 text-primary fw-bold">Danh sách Địa Điểm</h2>
            <button class="btn btn-primary px-4 rounded-pill shadow-sm" @onclick="MởFormThêmMới">
                <i class="bi bi-plus-circle me-1"></i> Thêm quán mới
            </button>
        </div>

        @if (isLoading)
        {
            <div class="text-center mt-5">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-2 text-muted">Đang tải dữ liệu từ API...</p>
            </div>
        }
        else if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger mt-3">@errorMessage</div>
        }
        else
        {
            <div class="table-responsive shadow-sm rounded border-0">
                <table class="table table-hover align-middle bg-white m-0 w-100">
                    <thead class="table-dark text-center">
                        <tr>
                            <th width="5%">ID</th>
                            <th width="10%">Ảnh</th>
                            <th width="25%" class="text-start">Tên Quán</th>
                            <th width="20%">Tọa độ & Bán kính</th>
                            <th width="12%">Trạng thái</th>
                            <th width="13%">Ngày tạo</th>
                            <th width="15%">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody class="text-center">
                        @foreach (var quan in danhSachQuan)
                        {
                            <tr>
                                <td><span class="text-muted small">#@quan.Poiid</span></td>
                                <td>
                                    <img src="@(string.IsNullOrEmpty(quan.Thumbnail) ? "img/no-image.png" : quan.Thumbnail)"
                                         class="rounded shadow-sm" style="width: 50px; height: 50px; object-fit: cover;" />
                                </td>
                                <td class="text-start">
                                    <div class="fw-bold text-primary">@quan.Name</div>
                                    <small class="text-muted">ID: @quan.Poiid</small>
                                </td>
                                <td>
                                    <div class="small fw-bold text-dark">@quan.Latitude, @quan.Longitude</div>
                                    <div class="badge bg-info-subtle text-info border border-info-subtle">R: @(quan.Radius ?? 0)m</div>
                                </td>
                                <td>
                                    @if (IsActiveStatus(quan.Status))
                                    {
                                        <span class="badge rounded-pill bg-success-subtle text-success border border-success-subtle">Hoạt động</span>
                                    }
                                    else if (string.Equals(quan.Status, "Pending", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="badge rounded-pill bg-warning-subtle text-warning border border-warning-subtle">Chờ duyệt</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-secondary-subtle text-secondary border border-secondary-subtle">Tạm ẩn</span>
                                    }
                                </td>
                                <td><span class="small text-muted">@quan.CreatedAt?.ToString("dd/MM/yyyy")</span></td>
                                <td>
                                    <button class="btn btn-light btn-sm rounded-3 border me-1" @onclick="() => MởFormSửa(quan)"><i class="bi bi-pencil"></i></button>
                                    <button class="btn btn-light btn-sm rounded-3 border text-danger" @onclick="() => HandleDeletePoi(quan)"><i class="bi bi-trash"></i></button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        @if (hienThiFormThem)
        {
            <div class="modal fade show d-block" style="background: rgba(0,0,0,0.6); backdrop-filter: blur(5px);">
                <div class="modal-dialog modal-dialog-centered modal-lg">
                    <div class="modal-content border-0 shadow-lg rounded-4">
                        <div class="modal-header bg-primary text-white rounded-top-4 border-0">
                            <h5 class="modal-title fw-bold"><i class="bi bi-plus-square-dotted me-2"></i>@(isEditMode ? "Cập Nhật Địa Điểm" : "Thêm Địa Điểm Mới")</h5>
                            <button type="button" class="btn-close btn-close-white" @onclick="ĐóngFormThêmMới"></button>
                        </div>
                        <div class="modal-body p-4 bg-light">
                            <div class="row g-3">
                                <div class="col-12">
                                    <label class="form-label fw-bold text-dark">Tên quán ốc</label>
                                    <input type="text" class="form-control form-control-lg shadow-sm border-0" @bind="newPoi.Name" placeholder="VD: Ốc Oanh Vĩnh Khánh">
                                </div>

                                <div class="col-12">
                                    <label class="form-label fw-bold text-dark">Link ảnh đại diện (Thumbnail URL)</label>
                                    <div class="input-group">
                                        <span class="input-group-text border-0 bg-white"><i class="bi bi-image"></i></span>
                                        <input type="text" class="form-control shadow-sm border-0" @bind="newPoi.Thumbnail" placeholder="https://example.com/hinh-anh.jpg">
                                    </div>
                                    <InputFile OnChange="OnPoiImageSelectedAsync" class="form-control mt-2" accept="image/*" />
                                    @if (isUploadingImage)
                                    {
                                        <div class="small text-muted mt-1">Đang tải ảnh...</div>
                                    }
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label fw-bold text-dark">Vĩ độ (Lat)</label>
                                    <input type="number" step="any" class="form-control shadow-sm border-0" @bind="newPoi.Latitude" placeholder="10.76xxx">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold text-dark">Kinh độ (Long)</label>
                                    <input type="number" step="any" class="form-control shadow-sm border-0" @bind="newPoi.Longitude" placeholder="106.7xxx">
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label fw-bold text-dark">Bán kính (m)</label>
                                    <input type="number" class="form-control shadow-sm border-0" @bind="newPoi.Radius" placeholder="VD: 50">
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label fw-bold text-dark">Trạng thái hiển thị</label>
                                    <select class="form-select shadow-sm border-0" @bind="newPoi.Status">
                                        <option value="Active">Hoạt động (Active)</option>
                                        <option value="Inactive">Tạm ẩn (Inactive)</option>
                                        <option value="Pending">Chờ duyệt (Pending)</option>
                                    </select>
                                </div>

                                <div class="col-12 mt-2">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <label class="form-label fw-bold text-dark m-0">Mô tả (Tiếng Việt)</label>
                                        <button type="button" class="btn btn-sm btn-outline-primary rounded-pill" @onclick="TranslateDescriptionsAsync" disabled="@isTranslatingDescriptions">
                                            @if (isTranslatingDescriptions)
                                            {
                                                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                                            }
                                            <i class="bi bi-translate me-1"></i>Dịch tự động 4 ngôn ngữ
                                        </button>
                                    </div>
                                    <textarea class="form-control shadow-sm border-0" rows="3" @bind="localizationInput.DescriptionVi" placeholder="Nhập mô tả tiếng Việt..."></textarea>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label fw-bold text-dark">Mô tả (English)</label>
                                    <textarea class="form-control shadow-sm border-0" rows="3" @bind="localizationInput.DescriptionEn"></textarea>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold text-dark">Mô tả (한국어)</label>
                                    <textarea class="form-control shadow-sm border-0" rows="3" @bind="localizationInput.DescriptionKo"></textarea>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold text-dark">Mô tả (中文)</label>
                                    <textarea class="form-control shadow-sm border-0" rows="3" @bind="localizationInput.DescriptionZh"></textarea>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold text-dark">Mô tả (日本語)</label>
                                    <textarea class="form-control shadow-sm border-0" rows="3" @bind="localizationInput.DescriptionJa"></textarea>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer bg-white border-0 rounded-bottom-4 shadow-sm">
                            <button type="button" class="btn btn-outline-secondary px-4 rounded-pill" @onclick="ĐóngFormThêmMới">Hủy bỏ</button>
                            <button type="button" class="btn btn-primary px-4 rounded-pill shadow-sm fw-bold" @onclick="HandleSavePoi" disabled="@isSaving">
                                @if (isSaving)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                    <span>Đang xử lý...</span>
                                }
                                else
                                {
                                    <i class="bi bi-cloud-arrow-up me-1"></i> @(isEditMode ? "Cập nhật" : "Lưu vào Hệ thống")
                                }
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </Authorized>

    <NotAuthorized>
        <div class="alert alert-danger mt-5 shadow-sm border-0 text-center">
            <h3 class="alert-heading"><i class="bi bi-shield-x" style="font-size: 3rem;"></i></h3>
            <h4>CẢNH BÁO AN NINH</h4>
            <p>Phiên đăng nhập đã hết hạn</p>
            <a href="/" class="btn btn-danger mt-3 px-4 rounded-pill">Quay về Đăng nhập</a>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private List<Poi> danhSachQuan = new();
    private string errorMessage = "";
    private bool isLoading = true;
    private bool isSaving = false;
    private bool hienThiFormThem = false;
    private bool isEditMode = false;
    private bool isUploadingImage;
    private bool isTranslatingDescriptions;

    // 1. KHAI BÁO BIẾN ĐỂ HỨNG DỮ LIỆU TỪ FORM THÊM MỚI
    private Poi newPoi = new Poi { Status = "Active", Radius = 50 };
    private PoiLocalizationInput localizationInput = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task OnPoiImageSelectedAsync(InputFileChangeEventArgs e)
    {
        if (e.File == null)
        {
            return;
        }

        isUploadingImage = true;
        try
        {
            using var content = new MultipartFormDataContent();
            await using var stream = e.File.OpenReadStream(5 * 1024 * 1024);
            var fileContent = new StreamContent(stream);
            fileContent.Headers.ContentType = new MediaTypeHeaderValue(e.File.ContentType);
            content.Add(fileContent, "file", e.File.Name);

            var response = await Http.PostAsync("api/uploads/poi", content);
            if (!response.IsSuccessStatusCode)
            {
                var message = await response.Content.ReadAsStringAsync();
                await ShowErrorAsync("Lỗi!", string.IsNullOrWhiteSpace(message) ? "Không thể tải ảnh." : message);
                return;
            }

            var json = await response.Content.ReadAsStringAsync();
            using var document = JsonDocument.Parse(json);
            if (document.RootElement.TryGetProperty("url", out var urlElement))
            {
                newPoi.Thumbnail = urlElement.GetString();
            }
        }
        catch (Exception ex)
        {
            await ShowErrorAsync("Lỗi!", $"Không thể tải ảnh: {ex.Message}");
        }
        finally
        {
            isUploadingImage = false;
        }
    }

    private async Task LoadData()
    {
        try
        {
            isLoading = true;
            danhSachQuan = await Http.GetFromJsonAsync<List<Poi>>("api/Pois") ?? new List<Poi>();
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await LocalStorage.RemoveItemAsync("authToken");
            await JS.InvokeVoidAsync("sessionStorage.removeItem", "authToken");
            Navigation.NavigateTo("/", forceLoad: true);
        }
        catch (HttpRequestException ex)
        {
            errorMessage = $"Không kết nối được API: {ex.Message}";
        }
        catch (System.Text.Json.JsonException ex)
        {
            errorMessage = $"Dữ liệu API không đúng định dạng: {ex.Message}";
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi xử lý dữ liệu: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void MởFormThêmMới()
    {
        // Reset lại dữ liệu mặc định khi mở form
        newPoi = new Poi { Status = "Active", Radius = 50, CreatedAt = DateTime.Now };
        localizationInput = new PoiLocalizationInput();
        isEditMode = false;
        hienThiFormThem = true;
    }

    private void MởFormSửa(Poi poi)
    {
        newPoi = new Poi
        {
            Poiid = poi.Poiid,
            Name = poi.Name,
            Latitude = poi.Latitude,
            Longitude = poi.Longitude,
            Radius = poi.Radius,
            Thumbnail = poi.Thumbnail,
            Status = poi.Status,
            CreatedAt = poi.CreatedAt
        };

        localizationInput = new PoiLocalizationInput
        {
            DescriptionVi = poi.Poilocalizations?.FirstOrDefault(x => x.LanguageCode == "vi")?.Description,
            DescriptionEn = poi.Poilocalizations?.FirstOrDefault(x => x.LanguageCode == "en")?.Description,
            DescriptionKo = poi.Poilocalizations?.FirstOrDefault(x => x.LanguageCode == "ko")?.Description,
            DescriptionZh = poi.Poilocalizations?.FirstOrDefault(x => x.LanguageCode == "zh")?.Description,
            DescriptionJa = poi.Poilocalizations?.FirstOrDefault(x => x.LanguageCode == "ja")?.Description
        };

        isEditMode = true;
        hienThiFormThem = true;
    }

    private void ĐóngFormThêmMới()
    {
        hienThiFormThem = false;
        isEditMode = false;
    }

    // 2. HÀM XỬ LÝ LƯU/CẬP NHẬT DỮ LIỆU
    private async Task HandleSavePoi()
    {
        if (isSaving)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(newPoi.Name))
        {
            await ShowErrorAsync("Lỗi!", "Vui lòng nhập tên quán!");
            return;
        }

        try
        {
            isSaving = true;
            var payload = new Poi
            {
                Poiid = newPoi.Poiid,
                Name = newPoi.Name?.Trim(),
                Latitude = newPoi.Latitude,
                Longitude = newPoi.Longitude,
                Radius = newPoi.Radius,
                Thumbnail = string.IsNullOrWhiteSpace(newPoi.Thumbnail) ? null : newPoi.Thumbnail.Trim(),
                Status = newPoi.Status,
                CreatedAt = newPoi.CreatedAt,
                Poilocalizations = new List<PoiLocalization>()
            };

            var response = isEditMode
                ? await Http.PutAsJsonAsync($"api/Pois/{newPoi.Poiid}", payload)
                : await Http.PostAsJsonAsync("api/Pois", payload);

            if (response.IsSuccessStatusCode)
            {
                var poiId = isEditMode
                    ? newPoi.Poiid
                    : (await response.Content.ReadFromJsonAsync<Poi>())?.Poiid;

                if (poiId.HasValue && poiId.Value > 0)
                {
                    var localizationResponse = await Http.PutAsJsonAsync($"api/Pois/{poiId.Value}/localizations", localizationInput);
                    if (!localizationResponse.IsSuccessStatusCode)
                    {
                        var localizationError = await localizationResponse.Content.ReadAsStringAsync();
                        await ShowErrorAsync("Lỗi!", $"Lưu địa điểm thành công nhưng lưu mô tả thất bại: {localizationError}");
                    }
                }

                await ShowSuccessAsync("Thành công!", isEditMode ? $"Đã cập nhật {newPoi.Name}." : $"Đã thêm {newPoi.Name} vào hệ thống.");
                hienThiFormThem = false;
                isEditMode = false;
                await LoadData(); // Tải lại bảng để thấy quán mới
            }
            else
            {
                var content = await response.Content.ReadAsStringAsync();
                await ShowErrorAsync("Lỗi!", $"Server từ chối lưu dữ liệu. {(int)response.StatusCode}: {content}");
            }
        }
        catch (Exception ex)
        {
            await ShowErrorAsync("Lỗi!", $"Không thể gửi dữ liệu đến API: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task TranslateDescriptionsAsync()
    {
        if (isTranslatingDescriptions)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(localizationInput.DescriptionVi))
        {
            await ShowErrorAsync("Thiếu dữ liệu", "Vui lòng nhập mô tả tiếng Việt trước khi dịch tự động.");
            return;
        }

        try
        {
            isTranslatingDescriptions = true;
            var response = await Http.PostAsJsonAsync("api/Pois/translate-description", new TranslateDescriptionRequest
            {
                DescriptionVi = localizationInput.DescriptionVi
            });

            if (!response.IsSuccessStatusCode)
            {
                var content = await response.Content.ReadAsStringAsync();
                await ShowErrorAsync("Lỗi dịch", string.IsNullOrWhiteSpace(content) ? "Không thể dịch mô tả tự động." : content);
                return;
            }

            var translated = await response.Content.ReadFromJsonAsync<PoiLocalizationInput>();
            if (translated != null)
            {
                localizationInput = translated;
            }
        }
        catch (Exception ex)
        {
            await ShowErrorAsync("Lỗi dịch", $"Không thể dịch mô tả tự động: {ex.Message}");
        }
        finally
        {
            isTranslatingDescriptions = false;
        }
    }

    private async Task HandleDeletePoi(Poi poi)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirmDeletePoi", poi.Name);
        if (!confirmed)
        {
            return;
        }

        try
        {
            var response = await Http.DeleteAsync($"api/Pois/{poi.Poiid}");

            if (response.IsSuccessStatusCode)
            {
                await ShowSuccessAsync("Đã xóa!", $"Đã xóa địa điểm {poi.Name}.");
                await LoadData();
            }
            else
            {
                var content = await response.Content.ReadAsStringAsync();
                await ShowErrorAsync("Lỗi!", $"Không thể xóa. {(int)response.StatusCode}: {content}");
            }
        }
        catch (Exception ex)
        {
            await ShowErrorAsync("Lỗi!", $"Không thể gửi yêu cầu xóa đến API: {ex.Message}");
        }
    }

    private async Task ShowSuccessAsync(string title, string message)
    {
        try
        {
            await JS.InvokeVoidAsync("showSuccessMessage", title, message);
        }
        catch (JSException)
        {
            errorMessage = $"{title} {message}";
            StateHasChanged();
        }
    }

    private async Task ShowErrorAsync(string title, string message)
    {
        try
        {
            await JS.InvokeVoidAsync("showErrorMessage", title, message);
        }
        catch (JSException)
        {
            errorMessage = $"{title} {message}";
            StateHasChanged();
        }
    }

    private static bool IsActiveStatus(string? status)
        => string.Equals(status, "Active", StringComparison.OrdinalIgnoreCase)
        || string.Equals(status, "1", StringComparison.OrdinalIgnoreCase);

    public class Poi
    {
        public int Poiid { get; set; }
        public string Name { get; set; }
        public double? Latitude { get; set; }
        public double? Longitude { get; set; }
        public double? Radius { get; set; }
        public string? Thumbnail { get; set; }
        public string? Status { get; set; }
        public DateTime? CreatedAt { get; set; }
        public List<PoiLocalization> Poilocalizations { get; set; } = new();
    }

    public class PoiLocalization
    {
        public string LanguageCode { get; set; } = string.Empty;
        public string? Description { get; set; }
    }

    public class PoiLocalizationInput
    {
        public string? DescriptionVi { get; set; }
        public string? DescriptionEn { get; set; }
        public string? DescriptionKo { get; set; }
        public string? DescriptionZh { get; set; }
        public string? DescriptionJa { get; set; }
    }

    public class TranslateDescriptionRequest
    {
        public string DescriptionVi { get; set; } = string.Empty;
    }
}
