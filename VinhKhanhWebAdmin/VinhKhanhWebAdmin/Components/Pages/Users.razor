@page "/users"

<PageTitle>Quản lý Users</PageTitle>

<AuthorizeView>
    <Authorized>
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <h3 class="fw-bold text-primary mb-2"><i class="bi bi-people me-2"></i>Quản lý Users</h3>
                <p class="text-muted mb-0">Tính năng đang phát triển</p>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="alert alert-danger mt-4">Bạn chưa đăng nhập. Vui lòng quay lại trang đăng nhập.</div>
    </NotAuthorized>
</AuthorizeView>
