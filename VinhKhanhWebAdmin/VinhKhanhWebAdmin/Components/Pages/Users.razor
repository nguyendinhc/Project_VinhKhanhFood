@page "/users"
@inject HttpClient Http
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Quản lý Users</PageTitle>

<AuthorizeView>
    <Authorized>
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="m-0 text-primary fw-bold"><i class="bi bi-people me-2"></i>Quản lý Users</h2>
            <div class="d-flex gap-2">
                <button class="btn btn-outline-primary rounded-pill" @onclick="LoadUsersAsync" disabled="@isLoading">
                    <i class="bi bi-arrow-clockwise me-1"></i>Làm mới
                </button>
                <button class="btn btn-primary rounded-pill" @onclick="OpenCreateModal">
                    <i class="bi bi-person-plus me-1"></i>Thêm user
                </button>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4 mb-3">
            <div class="card-body p-3">
                <div class="row g-2 align-items-end">
                    <div class="col-lg-5 col-md-6">
                        <label class="form-label small text-muted mb-1">Từ khóa</label>
                        <input class="form-control" @bind="keyword" placeholder="Username, họ tên, email..." />
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <label class="form-label small text-muted mb-1">Role</label>
                        <select class="form-select" @bind="selectedRoleId">
                            <option value="">Tất cả role</option>
                            @foreach (var role in roles)
                            {
                                <option value="@role.RoleId">@role.RoleName</option>
                            }
                        </select>
                    </div>
                    <div class="col-lg-2 col-md-6 d-flex gap-2">
                        <button class="btn btn-primary w-100" @onclick="ApplyFiltersAsync" disabled="@isLoading">Lọc</button>
                        <button class="btn btn-light border" @onclick="ResetFiltersAsync" disabled="@isLoading">Reset</button>
                    </div>
                </div>
            </div>
        </div>

        @if (isLoading)
        {
            <div class="text-center mt-5">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-2 text-muted">Đang tải danh sách người dùng...</p>
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="alert alert-danger mt-3">@errorMessage</div>
        }
        else
        {
            <div class="row g-3 mb-3">
                <div class="col-lg-3 col-md-6">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-body">
                            <div class="small text-muted">Tổng Users</div>
                            <div class="fs-4 fw-bold text-primary">@userResult.Summary.TotalUsers</div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-body">
                            <div class="small text-muted">Admin</div>
                            <div class="fs-4 fw-bold text-success">@userResult.Summary.AdminCount</div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-body">
                            <div class="small text-muted">Owner</div>
                            <div class="fs-4 fw-bold text-warning">@userResult.Summary.OwnerCount</div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-body">
                            <div class="small text-muted">Role khác/chưa gán</div>
                            <div class="fs-4 fw-bold text-secondary">@userResult.Summary.OtherRoleCount</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th width="8%">ID</th>
                                    <th width="20%">Username</th>
                                    <th width="22%">Họ tên</th>
                                    <th width="24%">Email</th>
                                    <th width="12%">Role</th>
                                    <th width="14%">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (userResult.Items.Count == 0)
                                {
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-4">Không có user nào phù hợp.</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var user in userResult.Items)
                                    {
                                        <tr>
                                            <td>#@user.UserId</td>
                                            <td class="fw-semibold">@user.UserName</td>
                                            <td>@(string.IsNullOrWhiteSpace(user.FullName) ? "-" : user.FullName)</td>
                                            <td>@(string.IsNullOrWhiteSpace(user.Email) ? "-" : user.Email)</td>
                                            <td>
                                                <span class="badge bg-info-subtle text-info border border-info-subtle">@(string.IsNullOrWhiteSpace(user.RoleName) ? "Chưa gán" : user.RoleName)</span>
                                            </td>
                                            <td>
                                                <div class="d-flex gap-1">
                                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => OpenEditModal(user)" disabled="@(!CanManageUser(user))" title="@GetCannotManageReason(user)">Sửa</button>
                                                    <button class="btn btn-sm btn-outline-warning" @onclick="() => OpenResetPasswordModal(user)" disabled="@(!CanManageUser(user))" title="@GetCannotManageReason(user)">Đặt lại MK</button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center mt-3">
                <div class="small text-muted">
                    Trang @userResult.Page / @userResult.TotalPages • @userResult.TotalCount users
                </div>
                <div class="d-flex align-items-center gap-2">
                    <select class="form-select form-select-sm" style="width: 90px;" @bind="pageSize" @bind:after="OnPageSizeChangedAsync">
                        <option value="10">10</option>
                        <option value="20">20</option>
                        <option value="50">50</option>
                    </select>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="PrevPageAsync" disabled="@(isLoading || userResult.Page <= 1)">Trước</button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="NextPageAsync" disabled="@(isLoading || userResult.Page >= userResult.TotalPages)">Sau</button>
                </div>
            </div>
        }

        @if (showUserModal)
        {
            <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content border-0 shadow rounded-4">
                        <div class="modal-header border-0 pb-0">
                            <h5 class="modal-title fw-bold text-primary">@(isEditMode ? "Cập nhật user" : "Thêm user mới")</h5>
                            <button type="button" class="btn-close" @onclick="CloseUserModal"></button>
                        </div>
                        <div class="modal-body">
                            @if (!string.IsNullOrWhiteSpace(modalErrorMessage))
                            {
                                <div class="alert alert-danger py-2">@modalErrorMessage</div>
                            }
                            <div class="mb-2">
                                <label class="form-label small text-muted">Username</label>
                                <input class="form-control" @bind="editingUser.UserName" disabled="@isEditMode" />
                            </div>
                            @if (!isEditMode)
                            {
                                <div class="mb-2">
                                    <label class="form-label small text-muted">Mật khẩu</label>
                                    <input class="form-control" type="password" @bind="editingUser.Password" />
                                </div>
                            }
                            <div class="mb-2">
                                <label class="form-label small text-muted">Họ tên</label>
                                <input class="form-control" @bind="editingUser.FullName" />
                            </div>
                            <div class="mb-2">
                                <label class="form-label small text-muted">Email</label>
                                <input class="form-control" @bind="editingUser.Email" />
                            </div>
                            <div>
                                <label class="form-label small text-muted">Role</label>
                                <select class="form-select" @bind="editingUser.RoleId">
                                    <option value="">Chưa gán</option>
                                    @foreach (var role in roles)
                                    {
                                        <option value="@role.RoleId">@role.RoleName</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="modal-footer border-0 pt-0">
                            <button class="btn btn-light border" @onclick="CloseUserModal" disabled="@isSaving">Hủy</button>
                            <button class="btn btn-primary" @onclick="SaveUserAsync" disabled="@isSaving">
                                @(isSaving ? "Đang lưu..." : "Lưu")
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (showResetPasswordModal)
        {
            <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content border-0 shadow rounded-4">
                        <div class="modal-header border-0 pb-0">
                            <h5 class="modal-title fw-bold text-warning">Đặt lại mật khẩu</h5>
                            <button type="button" class="btn-close" @onclick="CloseResetPasswordModal"></button>
                        </div>
                        <div class="modal-body">
                            @if (!string.IsNullOrWhiteSpace(passwordModalErrorMessage))
                            {
                                <div class="alert alert-danger py-2">@passwordModalErrorMessage</div>
                            }
                            <div class="small text-muted mb-2">User: <span class="fw-semibold">@selectedUserNameForPassword</span></div>
                            <label class="form-label small text-muted">Mật khẩu mới</label>
                            <input class="form-control" type="password" @bind="newPassword" />
                        </div>
                        <div class="modal-footer border-0 pt-0">
                            <button class="btn btn-light border" @onclick="CloseResetPasswordModal" disabled="@isSavingPassword">Hủy</button>
                            <button class="btn btn-warning text-white" @onclick="SaveNewPasswordAsync" disabled="@isSavingPassword">
                                @(isSavingPassword ? "Đang cập nhật..." : "Cập nhật mật khẩu")
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <div class="alert alert-danger mt-4">Bạn chưa đăng nhập. Vui lòng quay lại trang đăng nhập.</div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private UserPagedResult userResult = new();
    private List<RoleOption> roles = new();

    private bool isLoading = true;
    private bool isSaving;
    private bool isSavingPassword;
    private string errorMessage = string.Empty;
    private string modalErrorMessage = string.Empty;
    private string passwordModalErrorMessage = string.Empty;

    private string keyword = string.Empty;
    private int? selectedRoleId;
    private int page = 1;
    private int pageSize = 20;

    private int? currentUserId;

    private bool showUserModal;
    private bool isEditMode;
    private int? editingUserId;
    private EditUserModel editingUser = new();

    private bool showResetPasswordModal;
    private int? selectedUserIdForPassword;
    private string selectedUserNameForPassword = string.Empty;
    private string newPassword = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadCurrentUserContextAsync();
        await LoadRolesAsync();
        await LoadUsersAsync();
    }

    private async Task LoadCurrentUserContextAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userIdValue = authState.User?.FindFirst("UserId")?.Value;
        if (int.TryParse(userIdValue, out var parsedUserId))
        {
            currentUserId = parsedUserId;
        }
    }

    private async Task LoadRolesAsync()
    {
        try
        {
            roles = await Http.GetFromJsonAsync<List<RoleOption>>("api/users/roles") ?? new List<RoleOption>();
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await HandleUnauthorizedAsync();
        }
        catch
        {
            roles = new List<RoleOption>();
        }
    }

    private async Task LoadUsersAsync()
    {
        try
        {
            isLoading = true;
            errorMessage = string.Empty;

            var query = BuildQueryString();
            var result = await Http.GetFromJsonAsync<UserPagedResult>($"api/users?{query}");
            userResult = result ?? new UserPagedResult();
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await HandleUnauthorizedAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Không thể tải danh sách users: {ex.Message}";
            userResult = new UserPagedResult();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ApplyFiltersAsync()
    {
        page = 1;
        await LoadUsersAsync();
    }

    private async Task ResetFiltersAsync()
    {
        keyword = string.Empty;
        selectedRoleId = null;
        page = 1;
        pageSize = 20;
        await LoadUsersAsync();
    }

    private async Task PrevPageAsync()
    {
        if (page <= 1)
        {
            return;
        }

        page--;
        await LoadUsersAsync();
    }

    private async Task NextPageAsync()
    {
        if (page >= userResult.TotalPages)
        {
            return;
        }

        page++;
        await LoadUsersAsync();
    }

    private async Task OnPageSizeChangedAsync()
    {
        page = 1;
        await LoadUsersAsync();
    }

    private string BuildQueryString()
    {
        var query = new List<string>
        {
            $"page={page}",
            $"pageSize={pageSize}"
        };

        if (!string.IsNullOrWhiteSpace(keyword))
        {
            query.Add($"keyword={Uri.EscapeDataString(keyword)}");
        }

        if (selectedRoleId.HasValue)
        {
            query.Add($"roleId={selectedRoleId.Value}");
        }

        return string.Join("&", query);
    }

    private void OpenCreateModal()
    {
        editingUserId = null;
        isEditMode = false;
        modalErrorMessage = string.Empty;
        editingUser = new EditUserModel();
        showUserModal = true;
    }

    private void OpenEditModal(UserItem user)
    {
        if (!CanManageUser(user))
        {
            errorMessage = GetCannotManageReason(user);
            return;
        }

        editingUserId = user.UserId;
        isEditMode = true;
        modalErrorMessage = string.Empty;
        editingUser = new EditUserModel
        {
            UserName = user.UserName,
            FullName = user.FullName,
            Email = user.Email,
            RoleId = user.RoleId
        };
        showUserModal = true;
    }

    private void CloseUserModal()
    {
        showUserModal = false;
        modalErrorMessage = string.Empty;
    }

    private async Task SaveUserAsync()
    {
        if (isSaving)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(editingUser.UserName))
        {
            modalErrorMessage = "Username không được để trống.";
            return;
        }

        if (!isEditMode && string.IsNullOrWhiteSpace(editingUser.Password))
        {
            modalErrorMessage = "Mật khẩu không được để trống.";
            return;
        }

        try
        {
            isSaving = true;
            modalErrorMessage = string.Empty;

            HttpResponseMessage response;
            if (isEditMode && editingUserId.HasValue)
            {
                var updateRequest = new UpdateUserRequest
                {
                    FullName = editingUser.FullName,
                    Email = editingUser.Email,
                    RoleId = editingUser.RoleId
                };

                response = await Http.PutAsJsonAsync($"api/users/{editingUserId.Value}", updateRequest);
            }
            else
            {
                var createRequest = new CreateUserRequest
                {
                    UserName = editingUser.UserName,
                    Password = editingUser.Password,
                    FullName = editingUser.FullName,
                    Email = editingUser.Email,
                    RoleId = editingUser.RoleId
                };

                response = await Http.PostAsJsonAsync("api/users", createRequest);
            }

            if (response.IsSuccessStatusCode)
            {
                showUserModal = false;
                await LoadUsersAsync();
            }
            else
            {
                var content = await response.Content.ReadAsStringAsync();
                modalErrorMessage = string.IsNullOrWhiteSpace(content)
                    ? $"Không thể lưu user. Mã lỗi: {(int)response.StatusCode}."
                    : content;
            }
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await HandleUnauthorizedAsync();
        }
        catch (Exception ex)
        {
            modalErrorMessage = $"Không thể lưu user: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void OpenResetPasswordModal(UserItem user)
    {
        if (!CanManageUser(user))
        {
            errorMessage = GetCannotManageReason(user);
            return;
        }

        selectedUserIdForPassword = user.UserId;
        selectedUserNameForPassword = user.UserName;
        newPassword = string.Empty;
        passwordModalErrorMessage = string.Empty;
        showResetPasswordModal = true;
    }

    private void CloseResetPasswordModal()
    {
        showResetPasswordModal = false;
        passwordModalErrorMessage = string.Empty;
        newPassword = string.Empty;
    }

    private async Task SaveNewPasswordAsync()
    {
        if (isSavingPassword || !selectedUserIdForPassword.HasValue)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(newPassword))
        {
            passwordModalErrorMessage = "Mật khẩu mới không được để trống.";
            return;
        }

        try
        {
            isSavingPassword = true;
            passwordModalErrorMessage = string.Empty;

            var request = new ResetPasswordRequest
            {
                NewPassword = newPassword
            };

            var response = await Http.PutAsJsonAsync($"api/users/{selectedUserIdForPassword.Value}/password", request);
            if (response.IsSuccessStatusCode)
            {
                showResetPasswordModal = false;
            }
            else
            {
                var content = await response.Content.ReadAsStringAsync();
                passwordModalErrorMessage = string.IsNullOrWhiteSpace(content)
                    ? $"Không thể cập nhật mật khẩu. Mã lỗi: {(int)response.StatusCode}."
                    : content;
            }
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await HandleUnauthorizedAsync();
        }
        catch (Exception ex)
        {
            passwordModalErrorMessage = $"Không thể cập nhật mật khẩu: {ex.Message}";
        }
        finally
        {
            isSavingPassword = false;
        }
    }

    private async Task HandleUnauthorizedAsync()
    {
        await LocalStorage.RemoveItemAsync("authToken");
        await JS.InvokeVoidAsync("sessionStorage.removeItem", "authToken");
        Navigation.NavigateTo("/", forceLoad: true);
    }

    private bool CanManageUser(UserItem user)
    {
        if (user.RoleId != 1)
        {
            return true;
        }

        return currentUserId.HasValue && user.UserId == currentUserId.Value;
    }

    private string GetCannotManageReason(UserItem user)
    {
        return CanManageUser(user) ? string.Empty : "Không thể thao tác trên tài khoản Admin khác.";
    }

    public class UserPagedResult
    {
        public int TotalCount { get; set; }
        public int Page { get; set; } = 1;
        public int PageSize { get; set; } = 20;
        public int TotalPages { get; set; } = 1;
        public List<UserItem> Items { get; set; } = new();
        public UserSummary Summary { get; set; } = new();
    }

    public class UserSummary
    {
        public int TotalUsers { get; set; }
        public int AdminCount { get; set; }
        public int OwnerCount { get; set; }
        public int OtherRoleCount { get; set; }
    }

    public class UserItem
    {
        public int UserId { get; set; }
        public string UserName { get; set; } = string.Empty;
        public string? FullName { get; set; }
        public string? Email { get; set; }
        public int? RoleId { get; set; }
        public string? RoleName { get; set; }
    }

    public class RoleOption
    {
        public int RoleId { get; set; }
        public string RoleName { get; set; } = string.Empty;
    }

    public class EditUserModel
    {
        public string UserName { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public string? FullName { get; set; }
        public string? Email { get; set; }
        public int? RoleId { get; set; }
    }

    public class CreateUserRequest
    {
        public string UserName { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public string? FullName { get; set; }
        public string? Email { get; set; }
        public int? RoleId { get; set; }
    }

    public class UpdateUserRequest
    {
        public string? FullName { get; set; }
        public string? Email { get; set; }
        public int? RoleId { get; set; }
    }

    public class ResetPasswordRequest
    {
        public string NewPassword { get; set; } = string.Empty;
    }
}
