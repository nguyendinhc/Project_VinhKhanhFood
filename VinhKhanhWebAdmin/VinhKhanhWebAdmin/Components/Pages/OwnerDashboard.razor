                    <div class="small text-muted">Món ?ang kinh doanh</div>
                    <div class="fs-2 fw-bold text-primary">24</div>
                    <div class="small text-success">+2 món tu?n nŕy</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body">
                    <div class="small text-muted">L??t xem quán hôm nay</div>
                    <div class="fs-2 fw-bold text-info">186</div>
                    <div class="small text-muted">D? li?u realtime</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body">
                    <div class="small text-muted">Yęu c?u c?n x? lý</div>
                    <div class="fs-2 fw-bold text-danger">3</div>
                    <div class="small text-muted">C?p nh?t menu / ph?n h?i</div>
