@page "/owner-dashboard"
@attribute [Authorize(Roles = "Owner")]
@using Microsoft.AspNetCore.Authorization
@using System.Globalization
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject IJSRuntime JS
@inject HttpClient Http

<PageTitle>Bảng điều khiển chủ quán</PageTitle>

<div class="container-fluid p-0 owner-dashboard">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark m-0">Xin chào, <span class="text-warning">@displayName</span> 👋</h2>
            <p class="text-muted m-0">Đây là khu vực quản lý dành cho chủ quán.</p>
        </div>
        <button class="btn btn-white border shadow-sm rounded-pill px-3">
            <i class="bi bi-calendar-event me-2 text-secondary"></i> @DateTime.Now.ToString("dd/MM/yyyy")
        </button>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body">
                    <div class="small text-muted">Món đang kinh doanh</div>
                    <div class="fs-2 fw-bold text-primary">@activeMenus.ToString("N0")</div>
                    <div class="small text-muted">Tổng số món thuộc các quán của bạn</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body">
                    <div class="small text-muted">Lượt xem quán hôm nay</div>
                    <div class="fs-2 fw-bold text-info">@todayVisits.ToString("N0")</div>
                    <div class="small text-muted">Theo dữ liệu ghi nhận hôm nay</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body">
                    <div class="small text-muted">Số lượng quán hiện có</div>
                    <div class="fs-2 fw-bold text-warning">@ownerTotalPois.ToString("N0")</div>
                    <div class="small text-muted">Quán thuộc tài khoản của bạn</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 mt-4">
        <div class="card-body">
            <h5 class="fw-bold mb-3"><i class="bi bi-geo-alt-fill text-danger me-2"></i>Vị trí quán</h5>

            @if (!string.IsNullOrWhiteSpace(locationError))
            {
                <div class="alert alert-warning mb-0">@locationError</div>
            }
            else if (mapUrl is null)
            {
                <div class="text-muted">Chưa có dữ liệu vị trí quán.</div>
            }
            else
            {
                <div class="owner-map-frame rounded-4 overflow-hidden border" @onwheel:preventDefault="true">
                    <iframe src="@mapUrl" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
                </div>
                <div class="small text-muted mt-2">
                    Đang hiển thị vị trí: <b>@selectedPoiName</b> • Tổng @totalPoisOnMap quán
                </div>
                <div class="d-flex flex-wrap gap-2 mt-3">
                    @foreach (var poi in ownerPois)
                    {
                        <button class="btn btn-sm rounded-pill @(selectedPoiId == poi.Poiid ? "btn-danger" : "btn-outline-danger")"
                                @onclick="() => SelectPoi(poi)">
                            <i class="bi bi-geo-alt-fill me-1"></i>@poi.Name
                        </button>
                    }
                </div>
            }
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body">
            <h5 class="fw-bold mb-3"><i class="bi bi-lightning-charge-fill text-warning me-2"></i>Thao tác nhanh</h5>
            <div class="d-flex flex-wrap gap-2">
                <a href="/owner-pois" class="btn btn-outline-primary rounded-pill px-3">
                    <i class="bi bi-shop me-1"></i> Quản lý quán
                </a>
                <a href="/menus" class="btn btn-primary rounded-pill px-3">
                    <i class="bi bi-journal-text me-1"></i> Quản lý menu
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .owner-dashboard {
        font-family: 'Be Vietnam Pro', 'Segoe UI', 'Noto Sans', Arial, sans-serif;
    }

    .owner-map-frame {
        height: 420px;
    }

        .owner-map-frame iframe {
            width: 100%;
            height: 100%;
            border: 0;
        }

</style>

@code {
    private string displayName = "Owner";
    private string? mapUrl;
    private int ownerTotalPois;
    private int activeMenus;
    private int todayVisits;
    private int totalPoisOnMap;
    private readonly List<OwnerPoi> ownerPois = new();
    private int? selectedPoiId;
    private string selectedPoiName = "-";
    private string locationError = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var name = await LocalStorage.GetItemAsStringAsync("displayName");
        if (!string.IsNullOrWhiteSpace(name))
        {
            displayName = name;
        }
        else
        {
            var sessionName = await JS.InvokeAsync<string>("sessionStorage.getItem", "displayName");
            if (!string.IsNullOrWhiteSpace(sessionName))
            {
                displayName = sessionName;
            }
        }

        await Task.WhenAll(LoadOwnerLocationAsync(), LoadOwnerStatsAsync());
    }

    private async Task LoadOwnerStatsAsync()
    {
        try
        {
            var stats = await Http.GetFromJsonAsync<OwnerDashboardStats>("api/analytics/owner-dashboard") ?? new OwnerDashboardStats();
            ownerTotalPois = stats.TotalPois;
            activeMenus = stats.ActiveMenus;
            todayVisits = stats.TodayVisits;
        }
        catch
        {
            ownerTotalPois = 0;
            activeMenus = 0;
            todayVisits = 0;
        }
    }

    private async Task LoadOwnerLocationAsync()
    {
        try
        {
            locationError = string.Empty;
            var pois = await Http.GetFromJsonAsync<List<OwnerPoi>>("api/pois/owner") ?? new List<OwnerPoi>();
            if (pois.Count == 0)
            {
                mapUrl = null;
                ownerPois.Clear();
                selectedPoiId = null;
                selectedPoiName = "-";
                return;
            }

            totalPoisOnMap = pois.Count;
            ownerPois.Clear();
            ownerPois.AddRange(pois);
            SelectPoi(ownerPois[0]);
        }
        catch (Exception ex)
        {
            mapUrl = null;
            ownerPois.Clear();
            locationError = $"Không thể tải vị trí quán: {ex.Message}";
        }
    }

    private void SelectPoi(OwnerPoi poi)
    {
        selectedPoiId = poi.Poiid;
        selectedPoiName = poi.Name;

        var lat = poi.Latitude.ToString("0.######", CultureInfo.InvariantCulture);
        var lng = poi.Longitude.ToString("0.######", CultureInfo.InvariantCulture);
        mapUrl = $"https://maps.google.com/maps?output=embed&z=16&q={Uri.EscapeDataString($"{lat},{lng}")}";
    }

    public class OwnerPoi
    {
        public int Poiid { get; set; }
        public string Name { get; set; } = string.Empty;
        public double Latitude { get; set; }
        public double Longitude { get; set; }
    }

    public class OwnerDashboardStats
    {
        public int TotalPois { get; set; }
        public int ActiveMenus { get; set; }
        public int TodayVisits { get; set; }
    }

}
