@page "/owner-pois"
@attribute [Authorize(Roles = "Owner")]
@inject HttpClient Http
@using System.Net.Http.Headers
@using System.Text.Json

<PageTitle>Quản lý quán</PageTitle>

<AuthorizeView>
    <Authorized>
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="m-0 text-primary fw-bold"><i class="bi bi-shop me-2"></i>Quản lý quán</h2>
            <button class="btn btn-outline-primary rounded-pill" @onclick="LoadPois" disabled="@isLoading">
                <i class="bi bi-arrow-clockwise me-1"></i>Làm mới
            </button>
        </div>

        <div class="card border-0 shadow-sm rounded-4 mb-3">
            <div class="card-body">
                <h5 class="fw-bold mb-3">Thêm quán mới</h5>
                @if (!string.IsNullOrWhiteSpace(formError))
                {
                    <div class="alert alert-danger">@formError</div>
                }
                @if (availablePois.Count > 0)
                {
                    <div class="d-flex flex-wrap gap-3 mb-3">
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="create-poi-mode" id="claim-existing" checked="@isClaimExistingMode" @onchange="() => isClaimExistingMode = true" />
                            <label class="form-check-label" for="claim-existing">Nhận quán có sẵn</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="create-poi-mode" id="create-new" checked="@(!isClaimExistingMode)" @onchange="() => isClaimExistingMode = false" />
                            <label class="form-check-label" for="create-new">Tạo quán mới</label>
                        </div>
                    </div>
                }

                <div class="row g-3">
                    @if (isClaimExistingMode && availablePois.Count > 0)
                    {
                        <div class="col-12">
                            <label class="form-label small text-muted">Chọn quán chưa có chủ</label>
                            <select class="form-select" @bind="selectedAvailablePoiId">
                                <option value="">-- Chọn quán --</option>
                                @foreach (var poi in availablePois)
                                {
                                    <option value="@poi.Poiid">@poi.Name</option>
                                }
                            </select>
                        </div>
                    }
                    else
                    {
                        <div class="col-lg-4">
                            <label class="form-label small text-muted">Tên quán</label>
                            <input class="form-control" @bind="createModel.Name" placeholder="Tên quán" />
                        </div>
                        <div class="col-lg-3">
                            <label class="form-label small text-muted">Vĩ độ</label>
                            <input class="form-control" type="number" step="0.000001" @bind="createModel.Latitude" />
                        </div>
                        <div class="col-lg-3">
                            <label class="form-label small text-muted">Kinh độ</label>
                            <input class="form-control" type="number" step="0.000001" @bind="createModel.Longitude" />
                        </div>
                        <div class="col-lg-2">
                            <label class="form-label small text-muted">Bán kính (m)</label>
                            <input class="form-control" type="number" @bind="createModel.Radius" />
                        </div>
                        <div class="col-12">
                            <label class="form-label small text-muted">Ảnh (URL)</label>
                            <input class="form-control" @bind="createModel.Thumbnail" placeholder="https://..." />
                            <InputFile OnChange="OnCreatePoiImageSelectedAsync" class="form-control mt-2" accept="image/*" />
                            @if (isUploadingCreateImage)
                            {
                                <div class="small text-muted mt-1">Đang tải ảnh...</div>
                            }
                        </div>
                        <div class="col-12">
                            <label class="form-label small text-muted">Mô tả (Tiếng Việt)</label>
                            <textarea class="form-control" rows="3" @bind="createLocalization.DescriptionVi" placeholder="Nhập mô tả tiếng Việt..."></textarea>
                        </div>
                    }
                </div>
                <div class="d-flex justify-content-end mt-3">
                    <button class="btn btn-primary" @onclick="CreatePoiAsync" disabled="@isSaving">
                        @(isSaving ? "Đang lưu..." : (isClaimExistingMode && availablePois.Count > 0 ? "Nhận quán" : "Tạo quán"))
                    </button>
                </div>
            </div>
        </div>

        @if (ownerPois.Count > 0)
        {
            <div class="card border-0 shadow-sm rounded-4 mb-3">
                <div class="card-body">
                    <h5 class="fw-bold mb-3">Chỉnh sửa thông tin quán</h5>
                    @if (!string.IsNullOrWhiteSpace(updateError))
                    {
                        <div class="alert alert-danger">@updateError</div>
                    }
                    @if (selectedPoi != null && !IsPoiActive(selectedPoi.Status))
                    {
                        <div class="alert alert-warning">Quán đang tạm ẩn, không thể chỉnh sửa.</div>
                    }
                    <div class="row g-3">
                        <div class="col-lg-4">
                            <label class="form-label small text-muted">Tên quán</label>
                            <input class="form-control" @bind="updateModel.Name" placeholder="Tên quán" disabled="@IsUpdateLocked" />
                        </div>
                        <div class="col-lg-3">
                            <label class="form-label small text-muted">Vĩ độ</label>
                            <input class="form-control" type="number" step="0.000001" @bind="updateModel.Latitude" disabled="@IsUpdateLocked" />
                        </div>
                        <div class="col-lg-3">
                            <label class="form-label small text-muted">Kinh độ</label>
                            <input class="form-control" type="number" step="0.000001" @bind="updateModel.Longitude" disabled="@IsUpdateLocked" />
                        </div>
                        <div class="col-lg-2">
                            <label class="form-label small text-muted">Bán kính (m)</label>
                            <input class="form-control" type="number" @bind="updateModel.Radius" disabled="@IsUpdateLocked" />
                        </div>
                        <div class="col-12">
                            <label class="form-label small text-muted">Ảnh (URL)</label>
                            <input class="form-control" @bind="updateModel.Thumbnail" placeholder="https://..." disabled="@IsUpdateLocked" />
                            <InputFile OnChange="OnUpdatePoiImageSelectedAsync" class="form-control mt-2" accept="image/*" disabled="@IsUpdateLocked" />
                            @if (isUploadingUpdateImage)
                            {
                                <div class="small text-muted mt-1">Đang tải ảnh...</div>
                            }
                        </div>
                        <div class="col-12">
                            <label class="form-label small text-muted">Mô tả (Tiếng Việt)</label>
                            <textarea class="form-control" rows="3" @bind="updateLocalization.DescriptionVi" placeholder="Nhập mô tả tiếng Việt..." disabled="@IsUpdateLocked"></textarea>
                        </div>
                    </div>
                    <div class="d-flex justify-content-end mt-3">
                        <button class="btn btn-primary" @onclick="UpdatePoiAsync" disabled="@(isUpdating || IsUpdateLocked)">
                            @(isUpdating ? "Đang lưu..." : "Cập nhật")
                        </button>
                    </div>
                </div>
            </div>
        }

        @if (isLoading)
        {
            <div class="text-center mt-5">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-2 text-muted">Đang tải danh sách quán...</p>
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="alert alert-danger mt-3">@errorMessage</div>
        }
        else
        {
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                         <thead class="table-light">
                             <tr>
                                 <th width="15%">ID</th>
                                 <th>Tên quán</th>
                                <th width="20%">Thao tác</th>
                             </tr>
                         </thead>
                         <tbody>
                             @if (ownerPois.Count == 0)
                             {
                                 <tr>
                                    <td colspan="3" class="text-center text-muted py-4">Chưa có quán nào.</td>
                                 </tr>
                             }
                             else
                             {
                                 @foreach (var poi in ownerPois)
                                 {
                                      <tr>
                                         <td><span class="text-muted small">#@poi.Poiid</span></td>
                                         <td class="fw-semibold">@poi.Name</td>
                                            <td>
                                              <button class="btn btn-sm btn-outline-primary" @onclick="() => StartEdit(poi)" disabled="@(!IsPoiActive(poi.Status))">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                            </td>
                                     </tr>
                                 }
                             }
                         </tbody>
                     </table>
                    </div>
                </div>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <div class="alert alert-danger mt-4">Bạn chưa đăng nhập. Vui lòng quay lại trang đăng nhập.</div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private readonly List<OwnerPoi> ownerPois = new();
    private readonly List<AvailablePoi> availablePois = new();
    private OwnerPoiCreateModel createModel = new() { Radius = 50 };
    private OwnerPoiUpdateModel updateModel = new();
    private PoiLocalizationInput createLocalization = new();
    private PoiLocalizationInput updateLocalization = new();
    private OwnerPoi? selectedPoi;
    private int? selectedAvailablePoiId;
    private bool isClaimExistingMode = true;
    private bool isLoading = true;
    private bool isSaving;
    private bool isUpdating;
    private string errorMessage = string.Empty;
    private string formError = string.Empty;
    private string updateError = string.Empty;
    private bool IsUpdateLocked => selectedPoi != null && !IsPoiActive(selectedPoi.Status);
    private bool isUploadingCreateImage;
    private bool isUploadingUpdateImage;

    protected override async Task OnInitializedAsync()
    {
        await LoadPois();
    }

    private async Task OnCreatePoiImageSelectedAsync(InputFileChangeEventArgs e)
    {
        formError = string.Empty;

        var file = e.File;
        if (file == null)
        {
            return;
        }

        isUploadingCreateImage = true;
        try
        {
            using var content = new MultipartFormDataContent();
            await using var stream = file.OpenReadStream(5 * 1024 * 1024);
            var fileContent = new StreamContent(stream);
            fileContent.Headers.ContentType = new MediaTypeHeaderValue(file.ContentType);
            content.Add(fileContent, "file", file.Name);

            var response = await Http.PostAsync("api/uploads/poi", content);
            if (!response.IsSuccessStatusCode)
            {
                var message = await response.Content.ReadAsStringAsync();
                formError = string.IsNullOrWhiteSpace(message) ? "Không thể tải ảnh." : message;
                return;
            }

            var json = await response.Content.ReadAsStringAsync();
            using var document = JsonDocument.Parse(json);
            if (document.RootElement.TryGetProperty("url", out var urlElement))
            {
                createModel.Thumbnail = urlElement.GetString();
            }
        }
        catch (Exception ex)
        {
            formError = $"Không thể tải ảnh: {ex.Message}";
        }
        finally
        {
            isUploadingCreateImage = false;
        }
    }

    private async Task OnUpdatePoiImageSelectedAsync(InputFileChangeEventArgs e)
    {
        updateError = string.Empty;

        var file = e.File;
        if (file == null)
        {
            return;
        }

        isUploadingUpdateImage = true;
        try
        {
            using var content = new MultipartFormDataContent();
            await using var stream = file.OpenReadStream(5 * 1024 * 1024);
            var fileContent = new StreamContent(stream);
            fileContent.Headers.ContentType = new MediaTypeHeaderValue(file.ContentType);
            content.Add(fileContent, "file", file.Name);

            var response = await Http.PostAsync("api/uploads/poi", content);
            if (!response.IsSuccessStatusCode)
            {
                var message = await response.Content.ReadAsStringAsync();
                updateError = string.IsNullOrWhiteSpace(message) ? "Không thể tải ảnh." : message;
                return;
            }

            var json = await response.Content.ReadAsStringAsync();
            using var document = JsonDocument.Parse(json);
            if (document.RootElement.TryGetProperty("url", out var urlElement))
            {
                updateModel.Thumbnail = urlElement.GetString();
            }
        }
        catch (Exception ex)
        {
            updateError = $"Không thể tải ảnh: {ex.Message}";
        }
        finally
        {
            isUploadingUpdateImage = false;
        }
    }

    private async Task LoadPois()
    {
        try
        {
            isLoading = true;
            errorMessage = string.Empty;

            var data = await Http.GetFromJsonAsync<List<OwnerPoi>>("api/pois/owner");
            ownerPois.Clear();
            if (data is not null)
            {
                ownerPois.AddRange(data);
            }

            var availableData = await Http.GetFromJsonAsync<List<AvailablePoi>>("api/pois/owner/available");
            availablePois.Clear();
            if (availableData is not null)
            {
                availablePois.AddRange(availableData);
            }

            if (availablePois.Count == 0)
            {
                isClaimExistingMode = false;
            }

            selectedAvailablePoiId = availablePois.FirstOrDefault()?.Poiid;
            selectedPoi = ownerPois.FirstOrDefault();
            if (selectedPoi != null)
            {
                updateModel = new OwnerPoiUpdateModel
                {
                    Poiid = selectedPoi.Poiid,
                    Name = selectedPoi.Name,
                    Latitude = selectedPoi.Latitude,
                    Longitude = selectedPoi.Longitude,
                    Radius = selectedPoi.Radius,
                    Thumbnail = selectedPoi.Thumbnail
                };
                updateLocalization = new PoiLocalizationInput
                {
                    DescriptionVi = selectedPoi.Poilocalizations?.FirstOrDefault(x => x.LanguageCode == "vi")?.Description,
                    DescriptionEn = selectedPoi.Poilocalizations?.FirstOrDefault(x => x.LanguageCode == "en")?.Description,
                    DescriptionKo = selectedPoi.Poilocalizations?.FirstOrDefault(x => x.LanguageCode == "ko")?.Description,
                    DescriptionZh = selectedPoi.Poilocalizations?.FirstOrDefault(x => x.LanguageCode == "zh")?.Description,
                    DescriptionJa = selectedPoi.Poilocalizations?.FirstOrDefault(x => x.LanguageCode == "ja")?.Description
                };
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Không thể tải danh sách quán: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task CreatePoiAsync()
    {
        formError = string.Empty;

        OwnerPoiCreateModel request;
        var shouldClaimExisting = isClaimExistingMode && availablePois.Count > 0;

        if (shouldClaimExisting)
        {
            if (!selectedAvailablePoiId.HasValue)
            {
                formError = "Vui lòng chọn quán chưa có chủ.";
                return;
            }

            request = new OwnerPoiCreateModel
            {
                Poiid = selectedAvailablePoiId
            };
        }
        else
        {
            if (string.IsNullOrWhiteSpace(createModel.Name))
            {
                formError = "Vui lòng nhập tên quán.";
                return;
            }

            request = createModel;
        }

        isSaving = true;
        try
        {
            var response = await Http.PostAsJsonAsync("api/pois/owner", request);
            if (!response.IsSuccessStatusCode)
            {
                var message = await response.Content.ReadAsStringAsync();
                formError = string.IsNullOrWhiteSpace(message) ? "Không thể tạo quán." : message;
                return;
            }

            var created = await response.Content.ReadFromJsonAsync<OwnerPoi>();
            if (!shouldClaimExisting && created != null && created.Poiid > 0)
            {
                await Http.PutAsJsonAsync($"api/pois/owner/{created.Poiid}/localizations", createLocalization);
            }

            createModel = new OwnerPoiCreateModel { Radius = 50 };
            createLocalization = new PoiLocalizationInput();
            await LoadPois();
        }
        catch (Exception ex)
        {
            formError = $"Không thể tạo quán: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void StartEdit(OwnerPoi poi)
    {
        selectedPoi = poi;
        updateError = string.Empty;
        updateModel = new OwnerPoiUpdateModel
        {
            Poiid = poi.Poiid,
            Name = poi.Name,
            Latitude = poi.Latitude,
            Longitude = poi.Longitude,
            Radius = poi.Radius,
            Thumbnail = poi.Thumbnail
        };
        updateLocalization = new PoiLocalizationInput
        {
            DescriptionVi = poi.Poilocalizations?.FirstOrDefault(x => x.LanguageCode == "vi")?.Description,
            DescriptionEn = poi.Poilocalizations?.FirstOrDefault(x => x.LanguageCode == "en")?.Description,
            DescriptionKo = poi.Poilocalizations?.FirstOrDefault(x => x.LanguageCode == "ko")?.Description,
            DescriptionZh = poi.Poilocalizations?.FirstOrDefault(x => x.LanguageCode == "zh")?.Description,
            DescriptionJa = poi.Poilocalizations?.FirstOrDefault(x => x.LanguageCode == "ja")?.Description
        };
    }

    private async Task UpdatePoiAsync()
    {
        updateError = string.Empty;

        if (IsUpdateLocked)
        {
            updateError = "Quán đang tạm ẩn, không thể chỉnh sửa.";
            return;
        }

        if (updateModel.Poiid == 0)
        {
            updateError = "Không tìm thấy quán để cập nhật.";
            return;
        }

        if (string.IsNullOrWhiteSpace(updateModel.Name))
        {
            updateError = "Vui lòng nhập tên quán.";
            return;
        }

        isUpdating = true;
        try
        {
            var response = await Http.PutAsJsonAsync($"api/pois/owner/{updateModel.Poiid}", updateModel);
            if (!response.IsSuccessStatusCode)
            {
                var message = await response.Content.ReadAsStringAsync();
                updateError = string.IsNullOrWhiteSpace(message) ? "Không thể cập nhật quán." : message;
                return;
            }

            var localizationResponse = await Http.PutAsJsonAsync($"api/pois/owner/{updateModel.Poiid}/localizations", updateLocalization);
            if (!localizationResponse.IsSuccessStatusCode)
            {
                var message = await localizationResponse.Content.ReadAsStringAsync();
                updateError = string.IsNullOrWhiteSpace(message) ? "Cập nhật quán thành công nhưng lưu mô tả thất bại." : message;
                return;
            }

            await LoadPois();
        }
        catch (Exception ex)
        {
            updateError = $"Không thể cập nhật quán: {ex.Message}";
        }
        finally
        {
            isUpdating = false;
        }
    }

    public class OwnerPoi
    {
        public int Poiid { get; set; }
        public string Name { get; set; } = string.Empty;
        public double Latitude { get; set; }
        public double Longitude { get; set; }
        public int? Radius { get; set; }
        public string? Thumbnail { get; set; }
        public string? Status { get; set; }
        public List<PoiLocalization> Poilocalizations { get; set; } = new();
    }

    public class OwnerPoiCreateModel
    {
        public int? Poiid { get; set; }
        public string Name { get; set; } = string.Empty;
        public double Latitude { get; set; }
        public double Longitude { get; set; }
        public int? Radius { get; set; }
        public string? Thumbnail { get; set; }
    }

    public class AvailablePoi
    {
        public int Poiid { get; set; }
        public string Name { get; set; } = string.Empty;
        public double Latitude { get; set; }
        public double Longitude { get; set; }
        public int? Radius { get; set; }
        public string? Thumbnail { get; set; }
        public string? Status { get; set; }
    }

    public class OwnerPoiUpdateModel
    {
        public int Poiid { get; set; }
        public string Name { get; set; } = string.Empty;
        public double Latitude { get; set; }
        public double Longitude { get; set; }
        public int? Radius { get; set; }
        public string? Thumbnail { get; set; }
    }

    public class PoiLocalization
    {
        public string LanguageCode { get; set; } = string.Empty;
        public string? Description { get; set; }
        public string? AudioUrl { get; set; }
    }

    public class PoiLocalizationInput
    {
        public string? DescriptionVi { get; set; }
        public string? DescriptionEn { get; set; }
        public string? DescriptionKo { get; set; }
        public string? DescriptionZh { get; set; }
        public string? DescriptionJa { get; set; }
    }

    private static bool IsPoiActive(string? status)
        => string.Equals(status, "Active", StringComparison.OrdinalIgnoreCase)
            || string.Equals(status, "1", StringComparison.OrdinalIgnoreCase);
}
