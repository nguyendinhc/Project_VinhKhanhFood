@page "/analytics"
@attribute [Authorize(Roles = "Admin")]
@inject HttpClient Http
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>Thống kê số liệu</PageTitle>

<AuthorizeView>
    <Authorized>
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="m-0 text-primary fw-bold"><i class="bi bi-graph-up-arrow me-2"></i>Thống kê số liệu</h2>
            <button class="btn btn-outline-primary rounded-pill" @onclick="LoadDashboardAsync" disabled="@isLoading">
                <i class="bi bi-arrow-clockwise me-1"></i>Làm mới
            </button>
        </div>

        @if (isLoading)
        {
            <div class="text-center mt-5">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-2 text-muted">Đang tải dữ liệu thống kê...</p>
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="alert alert-danger mt-3">@errorMessage</div>
        }
        else if (dashboard is null)
        {
            <div class="alert alert-warning mt-3">Không có dữ liệu thống kê.</div>
        }
        else
        {
            <div class="row g-3 mb-3">
                <div class="col-lg-3 col-md-6">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-body">
                            <div class="text-muted small">Tổng số quán</div>
                            <div class="fs-3 fw-bold text-primary">@dashboard.TotalPois</div>
                            <div class="small text-muted">@dashboard.ActivePois hoạt động • @dashboard.PendingPois chờ duyệt • @dashboard.InactivePois tạm ẩn</div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-body">
                            <div class="text-muted small">Tổng số món ăn</div>
                            <div class="fs-3 fw-bold text-success">@dashboard.TotalMenus</div>
                            <div class="small text-muted">Toàn hệ thống Menu</div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-body">
                            <div class="text-muted small">Tổng lượt tương tác</div>
                            <div class="fs-3 fw-bold text-info">@dashboard.TotalVisits</div>
                            @* <div class="small text-muted">Từ bảng VisitLog</div> *@
                        </div>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-body">
                            <div class="text-muted small">Yêu cầu chờ duyệt</div>
                            <div class="fs-3 fw-bold text-warning">@((dashboard.PendingSubmissions + dashboard.PendingOwners + dashboard.PendingPois).ToString("N0"))</div>
                            <div class="small text-muted">Owner: @dashboard.PendingOwners • Quán: @dashboard.PendingPois • Y/c khác: @dashboard.PendingSubmissions</div>
                           @*  <div class="small text-muted">Từ bảng PoiSubmission</div> *@
                        </div>
                    </div>
                </div>
            </div>

            @if (appUsage is not null)
            {
                <div class="card border-0 shadow-sm rounded-4 mb-3 monitoring-panel">
                    <div class="card-header bg-white border-0 pt-3 px-3 d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 text-primary"><i class="bi bi-activity me-2"></i>Monitoring người dùng app</h5>
                        <span class="badge rounded-pill text-bg-light border">Near real-time</span>
                    </div>
                    <div class="card-body p-3">
                        <div class="row g-3">
                            <div class="col-xl-2 col-lg-4 col-md-6">
                                <div class="monitoring-card accent-primary">
                                    <div class="monitoring-label">Thiết bị cài lần đầu</div>
                                    <div class="monitoring-value">@appUsage.TotalInstalls.ToString("N0")</div>
                                    <div class="monitoring-note">Unique `app_first_open`</div>
                                </div>
                            </div>
                            <div class="col-xl-2 col-lg-4 col-md-6">
                                <div class="monitoring-card accent-success">
                                    <div class="monitoring-label">Thiết bị active hôm nay</div>
                                    <div class="monitoring-value">@appUsage.TodayActiveDevices.ToString("N0")</div>
                                    <div class="monitoring-note">Unique events today</div>
                                </div>
                            </div>
                            <div class="col-xl-2 col-lg-4 col-md-6">
                                <div class="monitoring-card accent-info">
                                    <div class="monitoring-label">Đã quét QR tổng</div>
                                    <div class="monitoring-value">@appUsage.TotalGlobalQrUsers.ToString("N0")</div>
                                    <div class="monitoring-note">Unique deviceId</div>
                                </div>
                            </div>
                            <div class="col-xl-2 col-lg-4 col-md-6">
                                <div class="monitoring-card accent-warning">
                                    <div class="monitoring-label">QR tổng hôm nay</div>
                                    <div class="monitoring-value">@appUsage.TodayGlobalQrUsers.ToString("N0")</div>
                                    <div class="monitoring-note">Unique deviceId</div>
                                </div>
                            </div>
                            <div class="col-xl-2 col-lg-4 col-md-6">
                                <div class="monitoring-card accent-purple">
                                    <div class="monitoring-label">Tổng lượt quét QR tổng</div>
                                    <div class="monitoring-value">@appUsage.TotalGlobalQrScans.ToString("N0")</div>
                                    <div class="monitoring-note">Count all scans</div>
                                </div>
                            </div>
                            <div class="col-xl-2 col-lg-4 col-md-6">
                                <div class="monitoring-card accent-dark">
                                    <div class="monitoring-label">Lượt quét hôm nay</div>
                                    <div class="monitoring-value">@appUsage.TodayGlobalQrScans.ToString("N0")</div>
                                    <div class="monitoring-note">Count today</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-lg-8">
                        <div class="card border-0 shadow-sm rounded-4 h-100">
                            <div class="card-header bg-white border-0 pt-3 px-3">
                                <h5 class="mb-0 text-primary">Xu hướng usage 7 ngày</h5>
                            </div>
                            <div class="card-body px-3">
                                @if (appUsage.UsageTrend.Count == 0)
                                {
                                    <div class="text-muted">Chưa có dữ liệu usage trend.</div>
                                }
                                else
                                {
                                    var chartWidth = 760;
                                    var chartHeight = 260;
                                    var chartPadding = 26;
                                    var chartTopPadding = 18;
                                    var chartBottomPadding = 34;
                                    var maxTrend = Math.Max(1, appUsage.UsageTrend.Max(x => Math.Max(x.ActiveDevices, Math.Max(x.Installs, x.GlobalQrScans))));
                                    var installPoints = BuildLinePoints(appUsage.UsageTrend, x => x.Installs, chartWidth, chartHeight, chartPadding, chartTopPadding, chartBottomPadding);
                                    var activePoints = BuildLinePoints(appUsage.UsageTrend, x => x.ActiveDevices, chartWidth, chartHeight, chartPadding, chartTopPadding, chartBottomPadding);
                                    var qrPoints = BuildLinePoints(appUsage.UsageTrend, x => x.GlobalQrScans, chartWidth, chartHeight, chartPadding, chartTopPadding, chartBottomPadding);
                                    var yTop = chartTopPadding;
                                    var yMid = (chartTopPadding + (chartHeight - chartBottomPadding)) / 2.0;
                                    var yBottom = chartHeight - chartBottomPadding;

                                    <div class="d-flex flex-wrap gap-3 small mb-2 chart-legend">
                                        <span><i class="bi bi-circle-fill text-primary me-1"></i>Install</span>
                                        <span><i class="bi bi-circle-fill text-success me-1"></i>Active</span>
                                        <span><i class="bi bi-circle-fill text-warning me-1"></i>QR scans</span>
                                    </div>

                                    <div class="usage-chart-wrap">
                                        <svg viewBox="0 0 @chartWidth @chartHeight" class="usage-svg">
                                            <line x1="@chartPadding" y1="@yTop" x2="@(chartWidth - chartPadding)" y2="@yTop" class="chart-grid" />
                                            <line x1="@chartPadding" y1="@yMid" x2="@(chartWidth - chartPadding)" y2="@yMid" class="chart-grid" />
                                            <line x1="@chartPadding" y1="@yBottom" x2="@(chartWidth - chartPadding)" y2="@yBottom" class="chart-grid" />

                                            <polyline points="@installPoints" class="chart-line line-install" />
                                            <polyline points="@activePoints" class="chart-line line-active" />
                                            <polyline points="@qrPoints" class="chart-line line-qr" />

                                            @for (var i = 0; i < appUsage.UsageTrend.Count; i++)
                                            {
                                                var item = appUsage.UsageTrend[i];
                                                var x = GetXForIndex(i, appUsage.UsageTrend.Count, chartWidth, chartPadding);
                                                var installY = GetYForValue(item.Installs, maxTrend, chartHeight, chartTopPadding, chartBottomPadding);
                                                var activeY = GetYForValue(item.ActiveDevices, maxTrend, chartHeight, chartTopPadding, chartBottomPadding);
                                                var qrY = GetYForValue(item.GlobalQrScans, maxTrend, chartHeight, chartTopPadding, chartBottomPadding);
                                                <circle cx="@x" cy="@installY" r="3.3" class="dot-install" />
                                                <circle cx="@x" cy="@activeY" r="3.3" class="dot-active" />
                                                <circle cx="@x" cy="@qrY" r="3.3" class="dot-qr" />
                                                <svg:text x="@x" y="@(chartHeight - 8)" text-anchor="middle" class="chart-x-label">@item.Date.ToString("dd/MM")</svg:text>
                                            }
                                        </svg>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-4">
                        <div class="card border-0 shadow-sm rounded-4 h-100">
                            <div class="card-header bg-white border-0 pt-3 px-3">
                                <h5 class="mb-0 text-primary">Gợi ý theo dõi</h5>
                            </div>
                            <div class="card-body px-3">
                                <div class="small text-muted mb-3">Tách rõ "user thiết bị" và "lượt tương tác" để đánh giá đúng hiệu quả.</div>
                                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                                    <span class="small">User/Install ratio</span>
                                    <span class="fw-semibold">@GetInstallToQrUserRatio(appUsage)%</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                                    <span class="small">QR repeat ratio</span>
                                    <span class="fw-semibold">@GetQrRepeatRatio(appUsage)%</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center py-2">
                                    <span class="small">Nhịp active hôm nay</span>
                                    <span class="fw-semibold">@GetActiveRate(appUsage)%</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <div class="row g-3 mb-3">
                <div class="col-lg-8">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-header bg-white border-0 pt-3 px-3">
                            <h5 class="mb-0 text-primary">Lượt ghé thăm 7 ngày gần nhất</h5>
                        </div>
                        <div class="card-body px-3">
                            @if (dashboard.VisitsTrend.Count == 0)
                            {
                                <div class="text-muted">Chưa có dữ liệu VisitLog.</div>
                            }
                            else
                            {
                                var maxVisits = Math.Max(1, dashboard.VisitsTrend.Max(x => x.TotalVisits));
                                @foreach (var item in dashboard.VisitsTrend)
                                {
                                    var width = item.TotalVisits == 0 ? 0 : (int)Math.Round(item.TotalVisits * 100.0 / maxVisits);
                                    <div class="mb-2">
                                        <div class="d-flex justify-content-between small">
                                            <span>@item.Date.ToString("dd/MM")</span>
                                            <span class="fw-semibold">@item.TotalVisits lượt</span>
                                        </div>
                                        <div class="progress" style="height: 10px;">
                                            <div class="progress-bar bg-info" style="width:@width%"></div>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-header bg-white border-0 pt-3 px-3">
                            <h5 class="mb-0 text-primary">Tỉ lệ hỗ trợ audio</h5>
                        </div>
                        <div class="card-body px-3">
                            @{
                                var hasPois = dashboard.TotalPois > 0;
                                var localizedRatio = hasPois ? (int)Math.Round(dashboard.LocalizedPois * 100.0 / dashboard.TotalPois) : 0;
                                localizedRatio = Math.Clamp(localizedRatio, 0, 100);
                            }
                            <div class="mb-2 small text-muted">Đã có thuyết minh: @dashboard.LocalizedPois / @dashboard.TotalPois quán</div>
                            <div class="progress" style="height:18px;">
                                <div class="progress-bar bg-success" role="progressbar" style="width:@($"{localizedRatio}%")" aria-valuemin="0" aria-valuemax="100" aria-valuenow="@localizedRatio">
                                    @localizedRatio%
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-lg-6">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-header bg-white border-0 pt-3 px-3">
                            <h5 class="mb-0 text-primary">Top 5 quán hot nhất</h5>
                        </div>
                        <div class="card-body px-3">
                            @if (dashboard.TopPois.Count == 0)
                            {
                                <div class="text-muted">Chưa có dữ liệu.</div>
                            }
                            else
                            {
                                var maxTop = Math.Max(1, dashboard.TopPois.Max(x => x.TotalVisits));
                                @foreach (var poi in dashboard.TopPois)
                                {
                                    var width = (int)Math.Round(poi.TotalVisits * 100.0 / maxTop);
                                    <div class="mb-2">
                                        <div class="d-flex justify-content-between small">
                                            <span class="text-truncate me-2">@poi.PoiName</span>
                                            <span class="fw-semibold">@poi.TotalVisits</span>
                                        </div>
                                        <div class="progress" style="height: 10px;">
                                            <div class="progress-bar bg-primary" style="width:@width%"></div>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-header bg-white border-0 pt-3 px-3">
                            <h5 class="mb-0 text-primary">Cảnh báo dữ liệu cần xử lý</h5>
                        </div>
                        <div class="card-body px-3">
                            <div class="mb-2">
                                <span class="badge bg-danger-subtle text-danger border border-danger-subtle me-2">Thiếu menu</span>
                                <span class="fw-semibold">@dashboard.PoisWithoutMenus quán</span>
                            </div>
                            <div class="mb-3">
                                <span class="badge bg-warning-subtle text-warning border border-warning-subtle me-2">Thiếu thumbnail</span>
                                <span class="fw-semibold">@dashboard.PoisWithoutThumbnail quán</span>
                            </div>

                            <div class="table-responsive">
                                <table class="table table-sm align-middle mb-0">
                                    <thead>
                                        <tr>
                                            <th>Quán</th>
                                            <th>Menu</th>
                                            <th>Ảnh</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (dashboard.WeakPois.Count == 0)
                                        {
                                            <tr>
                                                <td colspan="3" class="text-muted">Không có cảnh báo.</td>
                                            </tr>
                                        }
                                        else
                                        {
                                            @foreach (var poi in dashboard.WeakPois)
                                            {
                                                <tr>
                                                    <td class="text-truncate" style="max-width: 200px;">@poi.PoiName</td>
                                                    <td>
                                                        @if (poi.HasMenu)
                                                        {
                                                            <span class="badge bg-success-subtle text-success">Đủ</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge bg-danger-subtle text-danger">Thiếu</span>
                                                        }
                                                    </td>
                                                    <td>
                                                        @if (poi.HasThumbnail)
                                                        {
                                                            <span class="badge bg-success-subtle text-success">Đủ</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge bg-warning-subtle text-warning">Thiếu</span>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        }
    </Authorized>
    <NotAuthorized>
        <div class="alert alert-danger mt-4">Bạn chưa đăng nhập. Vui lòng quay lại trang đăng nhập.</div>
    </NotAuthorized>
</AuthorizeView>

<style>
    .monitoring-panel {
        background: linear-gradient(180deg, #ffffff 0%, #fbfcff 100%);
    }

    .monitoring-card {
        border: 1px solid #eef1f7;
        border-radius: 14px;
        padding: 12px;
        background: #fff;
        height: 100%;
    }

    .monitoring-label {
        font-size: 0.78rem;
        color: #6c757d;
    }

    .monitoring-value {
        font-size: 1.6rem;
        font-weight: 700;
        line-height: 1.2;
        margin-top: 3px;
    }

    .monitoring-note {
        font-size: 0.74rem;
        color: #9096a0;
        margin-top: 2px;
    }

    .accent-primary .monitoring-value { color: #0d6efd; }
    .accent-success .monitoring-value { color: #198754; }
    .accent-info .monitoring-value { color: #0dcaf0; }
    .accent-warning .monitoring-value { color: #f39c12; }
    .accent-purple .monitoring-value { color: #6f42c1; }
    .accent-dark .monitoring-value { color: #212529; }

    .chart-legend {
        color: #5f6b78;
    }

    .usage-chart-wrap {
        width: 100%;
        border: 1px solid #eef1f5;
        border-radius: 12px;
        padding: 10px 10px 4px 10px;
        background: linear-gradient(180deg, #ffffff 0%, #fbfcff 100%);
    }

    .usage-svg {
        width: 100%;
        height: 270px;
        display: block;
    }

    .chart-grid {
        stroke: #e8edf4;
        stroke-width: 1;
    }

    .chart-line {
        fill: none;
        stroke-width: 2.4;
        stroke-linecap: round;
        stroke-linejoin: round;
    }

    .line-install { stroke: #0d6efd; }
    .line-active { stroke: #198754; }
    .line-qr { stroke: #f39c12; }

    .dot-install { fill: #0d6efd; }
    .dot-active { fill: #198754; }
    .dot-qr { fill: #f39c12; }

    .chart-x-label {
        font-size: 11px;
        fill: #75808d;
    }
</style>

@code {
    private AnalyticsDashboard? dashboard;
    private AppUsage? appUsage;
    private bool isLoading = true;
    private string errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardAsync();
    }

    private async Task LoadDashboardAsync()
    {
        try
        {
            isLoading = true;
            errorMessage = string.Empty;
            dashboard = await Http.GetFromJsonAsync<AnalyticsDashboard>("api/analytics/dashboard");
            appUsage = await Http.GetFromJsonAsync<AppUsage>("api/analytics/usage");
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await LocalStorage.RemoveItemAsync("authToken");
            await JS.InvokeVoidAsync("sessionStorage.removeItem", "authToken");
            Navigation.NavigateTo("/", forceLoad: true);
        }
        catch (Exception ex)
        {
            errorMessage = $"Không thể tải dữ liệu thống kê: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    public class AnalyticsDashboard
    {
        public int TotalPois { get; set; }
        public int ActivePois { get; set; }
        public int PendingPois { get; set; }
        public int InactivePois { get; set; }
        public int TotalMenus { get; set; }
        public int TotalVisits { get; set; }
        public int PendingSubmissions { get; set; }
        public int PendingOwners { get; set; }
        public int LocalizedPois { get; set; }
        public int PoisWithoutMenus { get; set; }
        public int PoisWithoutThumbnail { get; set; }
        public List<VisitsTrendItem> VisitsTrend { get; set; } = new();
        public List<TopPoiItem> TopPois { get; set; } = new();
        public List<DataQualityPoiItem> WeakPois { get; set; } = new();
    }

    public class VisitsTrendItem
    {
        public DateTime Date { get; set; }
        public int TotalVisits { get; set; }
    }

    public class TopPoiItem
    {
        public int PoiId { get; set; }
        public string PoiName { get; set; } = string.Empty;
        public int TotalVisits { get; set; }
    }

    public class DataQualityPoiItem
    {
        public int PoiId { get; set; }
        public string PoiName { get; set; } = string.Empty;
        public bool HasMenu { get; set; }
        public bool HasThumbnail { get; set; }
    }

    public class AppUsage
    {
        public int TotalInstalls { get; set; }
        public int TodayActiveDevices { get; set; }
        public int TotalGlobalQrUsers { get; set; }
        public int TodayGlobalQrUsers { get; set; }
        public int TotalGlobalQrScans { get; set; }
        public int TodayGlobalQrScans { get; set; }
        public List<AppUsageTrendItem> UsageTrend { get; set; } = new();
    }

    public class AppUsageTrendItem
    {
        public DateTime Date { get; set; }
        public int Installs { get; set; }
        public int ActiveDevices { get; set; }
        public int GlobalQrScans { get; set; }
    }

    private static string BuildLinePoints(List<AppUsageTrendItem> items, Func<AppUsageTrendItem, int> selector, int width, int height, int padding, int topPadding, int bottomPadding)
    {
        if (items.Count == 0)
        {
            return string.Empty;
        }

        var max = Math.Max(1, items.Max(selector));
        var points = new List<string>(items.Count);
        for (var i = 0; i < items.Count; i++)
        {
            var x = GetXForIndex(i, items.Count, width, padding);
            var y = GetYForValue(selector(items[i]), max, height, topPadding, bottomPadding);
            points.Add($"{x:0.##},{y:0.##}");
        }

        return string.Join(" ", points);
    }

    private static double GetXForIndex(int index, int count, int width, int padding)
    {
        if (count <= 1)
        {
            return width / 2.0;
        }

        var plotWidth = width - (padding * 2.0);
        return padding + (plotWidth * index / (count - 1.0));
    }

    private static double GetYForValue(int value, int max, int height, int topPadding, int bottomPadding)
    {
        var plotHeight = height - topPadding - bottomPadding;
        var ratio = max <= 0 ? 0 : value / (double)max;
        return topPadding + ((1 - ratio) * plotHeight);
    }

    private static int GetInstallToQrUserRatio(AppUsage usage)
    {
        if (usage.TotalInstalls <= 0)
        {
            return 0;
        }

        return (int)Math.Round(usage.TotalGlobalQrUsers * 100.0 / usage.TotalInstalls);
    }

    private static int GetQrRepeatRatio(AppUsage usage)
    {
        if (usage.TotalGlobalQrUsers <= 0)
        {
            return 0;
        }

        return (int)Math.Round((usage.TotalGlobalQrScans - usage.TotalGlobalQrUsers) * 100.0 / usage.TotalGlobalQrUsers);
    }

    private static int GetActiveRate(AppUsage usage)
    {
        if (usage.TotalInstalls <= 0)
        {
            return 0;
        }

        return (int)Math.Round(usage.TodayActiveDevices * 100.0 / usage.TotalInstalls);
    }
}
