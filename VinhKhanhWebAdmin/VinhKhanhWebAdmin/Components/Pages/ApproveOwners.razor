@page "/approve-owners"

<PageTitle>Duyệt Chủ Quán</PageTitle>

<AuthorizeView>
    <Authorized>
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <h3 class="fw-bold text-primary mb-2"><i class="bi bi-person-check me-2"></i>Duyệt Chủ Quán</h3>
                <p class="text-muted mb-0">Tính năng đang phát triển.</p>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="alert alert-danger mt-4">Bạn chưa đăng nhập. Vui lòng quay lại trang đăng nhập.</div>
    </NotAuthorized>
</AuthorizeView>
